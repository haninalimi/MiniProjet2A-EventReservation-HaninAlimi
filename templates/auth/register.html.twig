{% extends 'base.html.twig' %}
{% block title %}Créer un compte{% endblock %}

{% block body %}
<div style="min-height:calc(100vh - 80px); display:flex; align-items:center; justify-content:center; padding:2rem 1rem;">
    <div style="width:100%; max-width:420px;">

        <div style="text-align:center; margin-bottom:2.5rem;">
            <div style="font-size:2.5rem; font-weight:900;" class="text-gradient">◈</div>
            <h2 style="font-weight:800; margin-top:.5rem;">Créer un compte</h2>
            <p style="color:var(--text-muted); font-size:.9rem;">Rejoignez EventApp en quelques secondes</p>
        </div>

        <div class="card-dark p-4">
            <div id="alert-box" style="margin-bottom:1rem;"></div>

            <div style="margin-bottom:1rem;">
                <label class="label-dark">Email</label>
                <input type="email" id="email" class="input-dark form-control"
                       placeholder="votre@email.com">
            </div>
            <div style="margin-bottom:1rem;">
                <label class="label-dark">Mot de passe</label>
                <input type="password" id="password" class="input-dark form-control"
                       placeholder="Minimum 6 caractères">
            </div>
            <div style="margin-bottom:1.5rem;">
                <label class="label-dark">Confirmer le mot de passe</label>
                <input type="password" id="confirm" class="input-dark form-control"
                       placeholder="••••••••">
            </div>

            <button id="btn-register" class="btn-glow btn w-100 btn-lg mb-3">
                <i class="bi bi-person-plus me-2"></i> Créer mon compte
            </button>

            <hr class="divider-glow">

            <div style="text-align:center; margin-bottom:1rem;">
                <p style="color:var(--text-muted); font-size:.8rem; margin-bottom:.75rem;">
                    Après inscription, activez la connexion biométrique
                </p>
                <button id="btn-register-passkey" class="btn-outline-glow btn w-100">
                    <i class="bi bi-fingerprint me-2"></i> Créer + activer Passkey
                </button>
            </div>

            <p style="text-align:center; color:var(--text-muted); font-size:.875rem; margin:0;">
                Déjà un compte ?
                <a href="{{ path('app_login') }}" style="color:var(--accent-violet); text-decoration:none; font-weight:600;">
                    Se connecter
                </a>
            </p>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script type="module">
    import { registerWithPassword, registerPasskey } from '/js/auth.js';

    const showAlert = (msg, type = 'danger') => {
        document.getElementById('alert-box').innerHTML =
            `<div class="alert-${type}-custom p-3" style="border-radius:10px; font-size:.875rem;">
                <i class="bi bi-${type === 'success' ? 'check-circle' : 'exclamation-circle'} me-2"></i>${msg}
            </div>`;
    };

    const setLoading = (btn, loading, text = 'Chargement...') => {
        btn.disabled = loading;
        btn.innerHTML = loading
            ? `<span class="spinner-border spinner-border-sm me-2"></span> ${text}`
            : btn.dataset.original;
    };

    document.addEventListener('DOMContentLoaded', () => {
        const btnReg = document.getElementById('btn-register');
        const btnPass = document.getElementById('btn-register-passkey');
        btnReg.dataset.original = btnReg.innerHTML;
        btnPass.dataset.original = btnPass.innerHTML;

        const getFormData = () => ({
            email: document.getElementById('email').value.trim(),
            password: document.getElementById('password').value,
            confirm: document.getElementById('confirm').value,
        });

        const validate = ({ email, password, confirm }) => {
            if (!email) return 'Email obligatoire.';
            if (password.length < 6) return 'Mot de passe trop court (min. 6 caractères).';
            if (password !== confirm) return 'Les mots de passe ne correspondent pas.';
            return null;
        };

        btnReg.addEventListener('click', async () => {
            const data = getFormData();
            const error = validate(data);
            if (error) return showAlert(error);
            setLoading(btnReg, true, 'Création...');
            try {
                await registerWithPassword(data.email, data.password);
                showAlert('Compte créé ! Redirection...', 'success');
                setTimeout(() => window.location.href = '/events', 800);
            } catch(e) {
                showAlert(e.message);
                setLoading(btnReg, false);
            }
        });

        btnPass.addEventListener('click', async () => {
            const data = getFormData();
            const error = validate(data);
            if (error) return showAlert(error);
            setLoading(btnPass, true, 'Création...');
            try {
                await registerWithPassword(data.email, data.password);
                await registerPasskey(data.email);
                showAlert('Compte créé avec Passkey ! Redirection...', 'success');
                setTimeout(() => window.location.href = '/events', 800);
            } catch(e) {
                showAlert(e.message);
                setLoading(btnPass, false);
            }
        });
    });
</script>
{% endblock %}
