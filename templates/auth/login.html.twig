{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-5">
            <div class="card shadow">
                <div class="card-header bg-dark text-white text-center py-3">
                    <h4 class="mb-0">
                        <i class="bi bi-box-arrow-in-right"></i> Connexion
                    </h4>
                </div>
                <div class="card-body p-4">
                    <div id="alert-box"></div>

                    <div class="mb-3">
                        <label class="form-label">Email</label>
                        <input type="email" id="email" class="form-control"
                               placeholder="votre@email.com">
                    </div>
                    <div class="mb-4">
                        <label class="form-label">Mot de passe</label>
                        <input type="password" id="password" class="form-control"
                               placeholder="••••••••">
                    </div>

                    <div class="d-grid gap-2">
                        <button id="btn-login" class="btn btn-primary btn-lg">
                            <i class="bi bi-box-arrow-in-right"></i> Se connecter
                        </button>
                        <div class="text-center text-muted my-2">— ou —</div>
                        <button id="btn-passkey" class="btn btn-outline-dark btn-lg">
                            <i class="bi bi-fingerprint"></i> Connexion avec Passkey
                        </button>
                    </div>

                    <hr>
                    <p class="text-center mb-0">
                        Pas encore de compte ?
                        <a href="{{ path('app_register') }}">Créer un compte</a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
<script type="module">
    import { loginWithPassword, loginWithPasskey } from '/js/auth.js';

    const showAlert = (msg, type = 'danger') => {
        document.getElementById('alert-box').innerHTML =
            `<div class="alert alert-${type}">${msg}</div>`;
    };

    document.getElementById('btn-login').addEventListener('click', async () => {
        const email = document.getElementById('email').value;
        const password = document.getElementById('password').value;
        if (!email || !password) return showAlert('Email et mot de passe requis.');
        try {
            await loginWithPassword(email, password);
            window.location.href = '/events';
        } catch (e) {
            showAlert(e.message);
        }
    });

    document.getElementById('btn-passkey').addEventListener('click', async () => {
        try {
            await loginWithPasskey();
            window.location.href = '/events';
        } catch (e) {
            showAlert(e.message);
        }
    });
</script>
{% endblock %}