{% extends 'base.html.twig' %}

{% block title %}Connexion{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/auth.css') }}">
{% endblock %}

{% block body %}
<div class="auth-page">
    <div class="auth-container">
        <div class="auth-header">
            <div class="auth-icon">◈</div>
            <h1 class="auth-title">Connexion</h1>
            <p class="auth-subtitle">Connectez-vous à votre collection</p>
        </div>

        <div class="auth-card">
            <div id="alert-box"></div>

            <div class="auth-tabs">
                <button id="tab-password" class="auth-tab active" onclick="switchTab('password')">
                    <i class="bi bi-lock"></i> Mot de passe
                </button>
                <button id="tab-passkey" class="auth-tab" onclick="switchTab('passkey')">
                    <i class="bi bi-fingerprint"></i> Passkey
                </button>
            </div>

            <div id="panel-password" class="auth-panel">
                <div class="auth-field">
                    <label class="auth-label">Email</label>
                    <input type="email" id="email" class="auth-input" 
                           placeholder="votre@email.com" autocomplete="email">
                </div>
                <div class="auth-field">
                    <label class="auth-label">Mot de passe</label>
                    <input type="password" id="password" class="auth-input" 
                           placeholder="••••••••" autocomplete="current-password">
                </div>
                <button id="btn-login" class="auth-button">
                    <i class="bi bi-box-arrow-in-right"></i>
                    <span>Se connecter</span>
                </button>
            </div>

            <div id="panel-passkey" class="auth-panel" style="display: none;">
                <div class="passkey-panel">
                    <div class="passkey-icon">
                        <i class="bi bi-fingerprint"></i>
                    </div>
                    <p class="passkey-description">
                        Utilisez votre empreinte digitale, Face ID ou PIN pour une connexion instantanée et sécurisée.
                    </p>
                    <button id="btn-passkey" class="auth-button">
                        <i class="bi bi-fingerprint"></i>
                        <span>Connexion biométrique</span>
                    </button>
                </div>
            </div>

            <div class="auth-divider">
                <span>OU</span>
            </div>

            <div class="auth-footer">
                <span>Première visite ? </span>
                <a href="{{ path('app_register') }}" class="auth-link">
                    Créer un compte <i class="bi bi-arrow-right ms-1"></i>
                </a>
            </div>
        </div>
    </div>
</div>
{% endblock %}

{% block javascripts %}
{{ parent() }}
<script type="module" src="{{ asset('js/login.js') }}"></script>
{% endblock %}