{% extends 'base.html.twig' %}

{% block title %}EventApp — L'Art de la Réservation{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/home.css') }}">
{% endblock %}

{% block body %}

<section class="book-section hero-lux" data-sec="0" data-page="— I —">
    <div class="hero-noise"></div>
    <div class="hero-vert-line"></div>

    <div class="hero-right-art">
        <div class="hero-hex">
            <div class="hex-ring" style="width:360px;height:360px;"></div>
            <div class="hex-ring"></div>
            <div class="hex-ring"></div>
            <div class="hex-ring"></div>
            <div class="hex-core">
                <svg viewBox="0 0 60 60" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <polygon points="30,4 56,18 56,42 30,56 4,42 4,18" fill="none" stroke="#c5a572" stroke-width="1.5"/>
                    <polygon points="30,12 48,22 48,38 30,48 12,38 12,22" fill="none" stroke="#c5a572" stroke-width=".8" opacity=".4"/>
                    <circle cx="30" cy="30" r="8" fill="none" stroke="#c5a572" stroke-width="1"/>
                    <circle cx="30" cy="30" r="3" fill="#c5a572"/>
                </svg>
            </div>
        </div>
       
    </div>

    <div class="hero-content">
        <h1 class="hero-h1">
            L'art de<br>
            réserver<br>
            <strong>l'exceptionnel</strong>
        </h1>
        <div class="typewriter-wrap">
            <span id="tw-text"></span><span class="tw-cursor"></span>
        </div>
        <div class="hero-btns">
            <a href="{{ path('event_index') }}" class="btn-or">Découvrir la collection</a>
            <a href="{{ path('app_register') }}" class="btn-outline-or">Créer son ex-libris</a>
        </div>
        <div class="hero-counter">
            <div>
                <div class="hc-label">Places disponibles</div>
                <div class="hc-value" id="hero-seats">{{ totalSeats ?? 157 }}</div>
            </div>
            <div class="hc-bar"><div class="hc-fill"></div></div>
            <div>
                <div class="hc-label">Événements</div>
                <div class="hc-value">{{ totalEvents }}</div>
            </div>
        </div>
    </div>

    <div class="hero-scroll-hint">
        <div class="scroll-mouse"><div class="scroll-ball"></div></div>
        <div class="scroll-text">Feuilleter</div>
    </div>
</section>

<div class="page-sep reveal-lux">
    <div class="sep-corner tl"></div><div class="sep-corner tr"></div>
    <div class="sep-corner bl"></div><div class="sep-corner br"></div>
    <div class="sep-line-full"></div>
    <div class="sep-center">
        <div class="sep-diamond-sm"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-label">Chapitre Premier — Chiffres</div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-sm"></div>
    </div>
</div>

<section class="book-section" data-sec="1" data-page="— II —">
    <div class="stats-lux reveal-lux">
        <div class="stat-cell">
            <div class="stat-num" data-target="{{ totalEvents }}" data-suffix="">0</div>
            <div class="stat-lbl">Événements</div>
            <div class="stat-sub">disponibles</div>
        </div>
        <div class="stat-cell">
            <div class="stat-num" data-target="500" data-suffix="+">0</div>
            <div class="stat-lbl">Participants</div>
            <div class="stat-sub">collectionneurs</div>
        </div>
        <div class="stat-cell">
            <div class="stat-num" data-target="100" data-suffix="%">0</div>
            <div class="stat-lbl">Sécurisé</div>
            <div class="stat-sub">Passkey FIDO2</div>
        </div>
        <div class="stat-cell">
            <div class="stat-num" data-target="30" data-suffix="s">0</div>
            <div class="stat-lbl">Réservation</div>
            <div class="stat-sub">chronométrée</div>
        </div>
    </div>
</section>

<div class="page-sep reveal-lux">
    <div class="sep-corner tl"></div><div class="sep-corner tr"></div>
    <div class="sep-corner bl"></div><div class="sep-corner br"></div>
    <div class="sep-line-full"></div>
    <div class="sep-center">
        <div class="sep-diamond-sm"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-label">Chapitre II — L'expérience</div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-sm"></div>
    </div>
</div>

<section class="book-section how-lux" data-sec="2" data-page="— III —" id="how">
    <div class="how-grid">
        <div class="reveal-lux">
            <div class="eyebrow">Comment ça marche</div>
            <h2 class="sec-h2" style="margin-bottom:3rem;">
                Réservez en<br><em>3 étapes</em> simples
            </h2>
            <div class="how-steps">
                <div class="how-step">
                    <div class="how-num">01</div>
                    <div>
                       <div class="how-title">Parcourez les événements</div>
<div class="how-desc">Découvrez tous les événements disponibles : concerts, conférences, workshops et hackathons. Filtrez par date, lieu ou catégorie.</div>
                    </div>
                </div>
                <div class="how-step">
                    <div class="how-num">02</div>
                    <div>
                       <div class="how-title">Connectez-vous en un clin d'œil</div>
<div class="how-desc">Utilisez votre empreinte digitale ou Face ID grâce à la technologie Passkey. Plus besoin de mots de passe, une connexion ultra-rapide et sécurisée.</div>
                    </div>
                </div>
                <div class="how-step">
                    <div class="how-num">03</div>
                    <div>
                      <div class="how-title">Réservez instantanément</div>
<div class="how-desc">En 30 secondes chrono, votre place est réservée. Confirmation immédiate par email et dans votre espace personnel.</div>
                    </div>
                </div>
            </div>
        </div>
        <div class="reveal-lux" style="display:flex;align-items:center;justify-content:center;">
            <div class="stack-wrap">
                <div class="stack-card">
                    <div class="stack-etag">Événement en vedette</div>
                    <div class="stack-etitle">Conférence Tech & Innovation 2026</div>
                    <div class="stack-bar"><div class="stack-fill" style="width:70%;"></div></div>
                    <div class="stack-info">8 / 12 places réservées</div>
                </div>
                <div class="stack-card">
                    <div class="stack-etag">Workshop</div>
                    <div class="stack-etitle">UI/UX Design Moderne</div>
                </div>
                <div class="stack-card">
                    <div class="stack-etag">Hackathon</div>
                    <div class="stack-etitle">Intelligence Artificielle</div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="page-sep reveal-lux" style="background:var(--bg2);">
    <div class="sep-corner tl"></div><div class="sep-corner tr"></div>
    <div class="sep-corner bl"></div><div class="sep-corner br"></div>
    <div class="sep-line-full"></div>
    <div class="sep-center" style="background:var(--bg2);">
        <div class="sep-diamond-sm"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-label">Chapitre III — Planches illustrées</div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-sm"></div>
    </div>
</div>

{% if featuredEvents is not empty %}
<section class="book-section events-lux" data-sec="3" data-page="— IV —">
    <div class="events-header">
        <div class="reveal-lux">
            <div class="eyebrow">Planches illustrées</div>
            <h2 class="sec-h2">Événements <em>en vedette</em></h2>
        </div>
        <a href="{{ path('event_index') }}" class="btn-outline-or reveal-lux"
           style="padding:.65rem 1.25rem;font-size:.6rem;">
            Voir tout le catalogue →
        </a>
    </div>
    <div class="events-grid">
        {% for event in featuredEvents %}
        <div class="flip-3d reveal-lux">
            <div class="flip-inner">
                <div class="flip-f">
                    <div class="card-img-wrap">
                        {% if event.image %}
                            <img src="{{ asset('uploads/events/' ~ event.image) }}" alt="{{ event.title }}">
                        {% else %}
                            <div class="card-img-placeholder">✦</div>
                        {% endif %}
                        <div class="card-seats-badge">{{ event.seats }} PLACES</div>
                    </div>
                    <div class="card-body-wrap">
                        <div class="card-etag">{{ event.date|date('d/m/Y') }} · {{ event.location }}</div>
                        <div class="card-etitle">{{ event.title }}</div>
                    </div>
                    <div style="padding:0 1.25rem 1.1rem;">
                        <div class="card-realtime">
                            <div>
                                <div class="rt-label">Places</div>
                                <div class="rt-value">{{ event.seats }}</div>
                            </div>
                            <div class="rt-bar">
                                <div class="rt-fill" style="width:65%;"></div>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="flip-b">
                    <div class="back-etitle">{{ event.title }}</div>
                    <div class="seats-track">
                        <div class="seats-fill-anim" style="width:65%;"></div>
                    </div>
                    <div class="back-info">
                        {{ event.seats }} places disponibles<br>
                        {{ event.location }}<br>
                        {{ event.date|date('d/m/Y à H:i') }}
                    </div>
                    <a href="{{ path('event_show', {id: event.id}) }}" class="btn-reserve">
                        Lire la suite →
                    </a>
                </div>
            </div>
        </div>
        {% endfor %}
    </div>
</section>
{% endif %}

<div class="page-sep reveal-lux">
    <div class="sep-corner tl"></div><div class="sep-corner tr"></div>
    <div class="sep-corner bl"></div><div class="sep-corner br"></div>
    <div class="sep-line-full"></div>
    <div class="sep-center">
        <div class="sep-diamond-sm"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-label">Marginalia — Notes des clients</div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-sm"></div>
    </div>
</div>

<section class="book-section testi-lux" data-sec="4" data-page="— V —">
    <div class="reveal-lux" style="text-align:center;max-width:1200px;margin:0 auto;">
        <div class="eyebrow" style="justify-content:center;">Marginalia</div>
        <h2 class="sec-h2">Notes des <em>clients</em></h2>
    </div>
    <div class="testi-grid">
        <div class="testi-card reveal-lux">
<p class="testi-text">"J'ai réservé ma place pour le concert en 20 secondes chrono. L'interface est magnifique et la connexion Passkey est révolutionnaire."</p>            <div class="testi-author">
                <div class="testi-av">SA</div>
                <div>
                    <div class="testi-name">Sofiene A.</div>
                    <div class="testi-role">Étudiant FIA3-GL</div>
                </div>
            </div>
        </div>
        <div class="testi-card reveal-lux">
            <p class="testi-text">"Design magistral. JWT + Passkeys, c'est exactement ce que l'industrie attendait. Une référence dans la réservation d'événements premium."</p>
            <div class="testi-author">
                <div class="testi-av" style="background:linear-gradient(135deg,#2a2a2a,#1a1a1a);color:var(--or);">MH</div>
                <div>
                    <div class="testi-name">Mohamed H.</div>
                    <div class="testi-role">Développeur Senior</div>
                </div>
            </div>
        </div>
        <div class="testi-card reveal-lux">
<p class="testi-text">"Enfin une plateforme qui allie design élégant et sécurité moderne. Les réservations sont instantanées et le suivi est parfait."</p>            <div class="testi-author">
                <div class="testi-av" style="background:linear-gradient(135deg,#1a1408,#2a1f0a);color:var(--or);">LB</div>
                <div>
                    <div class="testi-name">Leila B.</div>
                    <div class="testi-role">Chef de projet IT</div>
                </div>
            </div>
        </div>
    </div>
</section>

<div class="page-sep reveal-lux" style="background:var(--bg2);">
    <div class="sep-corner tl"></div><div class="sep-corner tr"></div>
    <div class="sep-corner bl"></div><div class="sep-corner br"></div>
    <div class="sep-line-full"></div>
    <div class="sep-center" style="background:var(--bg2);">
        <div class="sep-diamond-sm"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-label">Colophon — Rejoignez l'histoire</div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-sm"></div>
    </div>
</div>

<section class="book-section cta-lux" data-sec="5" data-page="— VI —">
    <div class="cta-frame reveal-lux">
        <div class="cta-collector">Édition Collector</div>
        <h2 class="cta-h2">
    Prêt à <em>réserver</em><br>
    votre prochain événement ?
</h2>
<p class="cta-sub">
    Rejoignez des milliers de participants qui font confiance à EventApp<br>
    pour vivre des expériences inoubliables.
</p>
        <div class="cta-btns">
<a href="{{ path('app_register') }}" class="btn-outline-or">Créer un compte</a>
            <a href="{{ path('event_index') }}" class="btn-outline-or">Feuilleter le catalogue</a>
        </div>
    </div>
</section>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/home.js') }}"></script>
{% endblock %}