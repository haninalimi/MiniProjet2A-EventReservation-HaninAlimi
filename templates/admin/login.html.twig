<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Connexion Admin — EventApp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/admin_login.css') }}">
</head>
<body>

<button class="theme-btn" id="themeBtn" title="Changer le thème">
    <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
</button>

<div class="login-wrap">

    <div class="login-header">
        <div class="login-logo">
            <div class="login-logo-mark">EA</div>
            <div>
                <div class="login-logo-name">EventApp</div>
                <div class="login-logo-sub">Administration</div>
            </div>
        </div>
        <div class="login-title">Connexion administrateur</div>
        <div class="login-sub">Accès réservé aux administrateurs</div>
    </div>

    <div class="login-card">

        {% if error is defined and error %}
        <div class="alert-error">
            <i class="bi bi-exclamation-circle"></i>
            {{ error.messageKey|trans(error.messageData, 'security') }}
        </div>
        {% endif %}

        <form method="post" action="{{ path('admin_login') }}">

            <div class="fg">
                <label for="username">Nom d'utilisateur</label>
                <input type="text"
                       id="username"
                       name="username"
                       value="{{ last_username ?? '' }}"
                       placeholder="admin"
                       autocomplete="username"
                       autofocus>
            </div>

            <div class="fg">
                <label for="password">Mot de passe</label>
                <input type="password"
                       id="password"
                       name="password"
                       placeholder="••••••••"
                       autocomplete="current-password">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <button type="submit" class="btn-submit">
                <i class="bi bi-box-arrow-in-right me-1"></i>
                Se connecter
            </button>

        </form>

        <div class="divider"></div>

        <div class="login-footer">
            <a href="{{ path('event_index') }}">
                <i class="bi bi-arrow-left me-1"></i>Retour au site
            </a>
        </div>

    </div>
</div>

<script src="{{ asset('js/admin_login.js') }}"></script>
</body>
</html>