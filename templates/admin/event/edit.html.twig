{% extends 'admin/base_admin.html.twig' %}
{% block title %}Modifier — {{ event.title }}{% endblock %}
{% block page_title %}Modifier un événement{% endblock %}

{% block content %}

<div class="adm-page-header">
    <div>
        <div class="adm-page-title">Modifier l'événement</div>
        <div class="adm-page-desc">{{ event.title }}</div>
    </div>
    <a href="{{ path('admin_event_index') }}" class="adm-btn adm-btn-ghost">
        <i class="bi bi-arrow-left"></i> Retour
    </a>
</div>

<div style="max-width:680px;">
    <div class="adm-card">
        <div class="adm-card-header">
            <div class="adm-card-title">
                <i class="bi bi-pencil"></i>
                Informations de l'événement
            </div>
        </div>
        <div style="padding:1.25rem;">

            {% if event.image %}
            <div style="margin-bottom:1.25rem;padding:.85rem;background:var(--adm-bg3);border:1px solid var(--adm-border);border-radius:6px;display:flex;align-items:center;gap:.85rem;">
                <img src="{{ asset('uploads/events/' ~ event.image) }}"
                     style="width:70px;height:46px;object-fit:cover;border-radius:4px;border:1px solid var(--adm-border);"
                     alt="image actuelle">
                <div>
                    <div style="font-size:.7rem;font-weight:500;color:var(--adm-text2);">Image actuelle</div>
                    <div style="font-size:.65rem;color:var(--adm-text3);font-family:'JetBrains Mono',monospace;">{{ event.image }}</div>
                </div>
            </div>
            {% endif %}

            {{ form_start(form) }}

            <div class="adm-form-group">
                <label class="adm-label">Titre</label>
                {{ form_widget(form.title, {'attr': {'class': 'adm-input'}}) }}
                {% if form_errors(form.title) %}
                    <div class="adm-field-error">{{ form_errors(form.title) }}</div>
                {% endif %}
            </div>

            <div class="adm-form-group">
                <label class="adm-label">Description</label>
                {{ form_widget(form.description, {'attr': {'class': 'adm-input', 'rows': 4, 'style': 'resize:vertical;min-height:100px;'}}) }}
                {% if form_errors(form.description) %}
                    <div class="adm-field-error">{{ form_errors(form.description) }}</div>
                {% endif %}
            </div>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;">
                <div class="adm-form-group">
                    <label class="adm-label">Date et heure</label>
                    {{ form_widget(form.date, {'attr': {'class': 'adm-input'}}) }}
                    {% if form_errors(form.date) %}
                        <div class="adm-field-error">{{ form_errors(form.date) }}</div>
                    {% endif %}
                </div>
                <div class="adm-form-group">
                    <label class="adm-label">Nombre de places</label>
                    {{ form_widget(form.seats, {'attr': {'class': 'adm-input', 'min': 1}}) }}
                    {% if form_errors(form.seats) %}
                        <div class="adm-field-error">{{ form_errors(form.seats) }}</div>
                    {% endif %}
                </div>
            </div>

            <div class="adm-form-group">
                <label class="adm-label">Lieu</label>
                {{ form_widget(form.location, {'attr': {'class': 'adm-input'}}) }}
                {% if form_errors(form.location) %}
                    <div class="adm-field-error">{{ form_errors(form.location) }}</div>
                {% endif %}
            </div>

            {% if form.imageFile is defined %}
            <div class="adm-form-group">
                <label class="adm-label">Nouvelle image <span style="color:var(--adm-text3);">(laisser vide pour garder l'actuelle)</span></label>
                {{ form_widget(form.imageFile, {'attr': {'class': 'adm-input', 'style': 'padding:.35rem .75rem;'}}) }}
                {% if form_errors(form.imageFile) %}
                    <div class="adm-field-error">{{ form_errors(form.imageFile) }}</div>
                {% endif %}
            </div>
            {% endif %}

            <div style="display:flex;gap:.75rem;margin-top:1.5rem;padding-top:1.25rem;border-top:1px solid var(--adm-border);">
                <button type="submit" class="adm-btn adm-btn-primary">
                    <i class="bi bi-check-lg"></i> Enregistrer les modifications
                </button>
                <a href="{{ path('admin_event_index') }}" class="adm-btn adm-btn-ghost">Annuler</a>
            </div>

            {{ form_end(form) }}
        </div>
    </div>
</div>

{% endblock %}
