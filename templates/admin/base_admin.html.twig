<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin{% endblock %} · EA/OPS</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">

    <link rel="stylesheet" href="{{ asset('css/admin.css') }}">

    {% block stylesheets %}{% endblock %}
</head>
<body>


<aside class="adm-sidebar" id="adminSidebar">

    <div class="adm-brand">
        <div class="adm-brand-mark">EA</div>
        <div>
            <div class="adm-brand-name">EVENTAPP</div>
            <div class="adm-brand-env">OPS · CONSOLE</div>
        </div>
    </div>

    <div class="adm-status-bar">
        <div class="adm-status-dot"></div>
        <span class="adm-status-text">System operational</span>
    </div>

    <nav class="adm-nav" aria-label="Navigation principale">

        <div class="adm-nav-group">
            <div class="adm-nav-group-label">Dashboard</div>
            <a href="{{ path('admin_dashboard') }}"
               class="adm-nav-item {% if app.request.attributes.get('_route') == 'admin_dashboard' %}active{% endif %}">
                <i class="bi bi-grid-1x2-fill"></i>
                Vue d'ensemble
            </a>
        </div>

        <div class="adm-nav-group">
            <div class="adm-nav-group-label">Catalogue</div>
            <a href="{{ path('admin_event_index') }}"
               class="adm-nav-item {% if 'admin_event' in app.request.attributes.get('_route') %}active{% endif %}">
                <i class="bi bi-calendar3"></i>
                Événements
            </a>
        </div>

        <div class="adm-nav-group">
            <div class="adm-nav-group-label">Liens rapides</div>
            <a href="{{ path('event_index') }}" class="adm-nav-item" target="_blank" rel="noopener">
                <i class="bi bi-box-arrow-up-right"></i>
                Voir le site
            </a>
        </div>

    </nav>

    <div class="adm-sidebar-foot">
        <div class="adm-user-card">
            <div class="adm-avatar">AD</div>
            <div>
                <div class="adm-user-name">Administrateur</div>
                <div class="adm-user-role">ROLE_ADMIN</div>
            </div>
        </div>
        <a href="{{ path('admin_logout') }}" class="adm-logout">
            <i class="bi bi-box-arrow-right"></i>
            Déconnexion
        </a>
    </div>

</aside>


<div class="adm-main">

    <header class="adm-topbar" role="banner">
        <div class="adm-breadcrumb">
            <span>ADMIN</span>
            <span class="bc-sep">/</span>
            <span class="bc-current">{% block page_title %}Dashboard{% endblock %}</span>
        </div>
        <div class="adm-topbar-right">
            <div class="adm-clock" id="adminClock" aria-live="polite">00:00:00</div>
            <button class="adm-icon-btn"
                    id="themeToggle"
                    onclick="Theme.toggle()"
                    title="Changer le thème"
                    aria-label="Toggle theme">
                <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
            </button>
            <a href="{{ path('event_index') }}"
               class="adm-icon-btn"
               target="_blank" rel="noopener"
               title="Voir le site public">
                <i class="bi bi-box-arrow-up-right"></i>
            </a>
        </div>
    </header>

    {% for type, messages in app.flashes %}
        {% for message in messages %}
        <div class="adm-flash-zone">
            <div class="adm-alert adm-alert-{{ type == 'success' ? 'success' : (type == 'warning' ? 'warning' : 'danger') }}"
                 role="alert">
                <i class="bi bi-{{ type == 'success' ? 'check-circle-fill' : 'exclamation-triangle-fill' }}"></i>
                {{ message }}
            </div>
        </div>
        {% endfor %}
    {% endfor %}

    <main class="adm-content" id="mainContent">
        {% block content %}{% endblock %}
    </main>

</div>

<script src="{{ asset('js/admin.js') }}"></script>
{% block javascripts %}{% endblock %}

</body>
</html>
