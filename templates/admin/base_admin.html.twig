<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Administration{% endblock %} — EventApp</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
        :root {
            --adm-bg: #0d1117;
            --adm-bg2: #161b22;
            --adm-bg3: #1c2128;
            --adm-bg4: #22272e;
            --adm-border: rgba(48,54,61,0.8);
            --adm-border2: rgba(48,54,61,0.4);
            --adm-text: #e6edf3;
            --adm-text2: #8b949e;
            --adm-text3: #484f58;
            --adm-accent: #c5a572;
            --adm-accent2: #e5c687;
            --adm-blue: #388bfd;
            --adm-green: #3fb950;
            --adm-red: #f85149;
            --adm-yellow: #d29922;
            --adm-sidebar: 240px;
        }

        [data-theme="light"] {
            --adm-bg: #f6f8fa;
            --adm-bg2: #ffffff;
            --adm-bg3: #f0f2f4;
            --adm-bg4: #e8eaed;
            --adm-border: rgba(208,215,222,0.8);
            --adm-border2: rgba(208,215,222,0.4);
            --adm-text: #1f2328;
            --adm-text2: #656d76;
            --adm-text3: #adb5bd;
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { font-size: 14px; }
        body {
            font-family: 'Inter', sans-serif;
            background: var(--adm-bg);
            color: var(--adm-text);
            min-height: 100vh;
            display: flex;
            overflow-x: hidden;
        }
        a { text-decoration: none; color: inherit; }
        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: var(--adm-bg); }
        ::-webkit-scrollbar-thumb { background: var(--adm-border); border-radius: 2px; }

        .adm-sidebar {
            width: var(--adm-sidebar);
            background: var(--adm-bg2);
            border-right: 1px solid var(--adm-border);
            min-height: 100vh;
            position: fixed;
            top: 0; left: 0;
            display: flex;
            flex-direction: column;
            z-index: 100;
            transition: background .3s;
        }

        .adm-sidebar-header {
            padding: 1.25rem 1rem;
            border-bottom: 1px solid var(--adm-border);
            display: flex;
            align-items: center;
            gap: .75rem;
        }

        .adm-logo-mark {
            width: 30px; height: 30px;
            background: var(--adm-accent);
            border-radius: 4px;
            display: flex; align-items: center; justify-content: center;
            flex-shrink: 0;
            font-size: .8rem;
            font-weight: 700;
            color: var(--adm-bg);
            font-family: 'JetBrains Mono', monospace;
        }

        .adm-logo-text {
            font-size: .875rem;
            font-weight: 600;
            color: var(--adm-text);
            line-height: 1.2;
        }
        .adm-logo-sub {
            font-size: .65rem;
            color: var(--adm-text3);
            font-family: 'JetBrains Mono', monospace;
        }

        .adm-nav { padding: .75rem 0; flex: 1; overflow-y: auto; }

        .adm-nav-section {
            padding: .5rem 1rem .25rem;
            font-size: .62rem;
            font-weight: 600;
            letter-spacing: .1em;
            text-transform: uppercase;
            color: var(--adm-text3);
            font-family: 'JetBrains Mono', monospace;
        }

        .adm-nav-item {
            display: flex;
            align-items: center;
            gap: .65rem;
            padding: .55rem 1rem;
            color: var(--adm-text2);
            font-size: .82rem;
            font-weight: 400;
            cursor: pointer;
            transition: all .15s;
            border-left: 2px solid transparent;
            margin: 1px 0;
        }
        .adm-nav-item:hover {
            background: var(--adm-bg3);
            color: var(--adm-text);
            border-left-color: var(--adm-border);
        }
        .adm-nav-item.active {
            background: rgba(197,165,114,0.08);
            color: var(--adm-accent);
            border-left-color: var(--adm-accent);
            font-weight: 500;
        }
        .adm-nav-item i { font-size: .9rem; width: 16px; flex-shrink: 0; }

        .adm-nav-badge {
            margin-left: auto;
            background: var(--adm-bg4);
            color: var(--adm-text3);
            font-family: 'JetBrains Mono', monospace;
            font-size: .6rem;
            padding: .1rem .4rem;
            border-radius: 10px;
            border: 1px solid var(--adm-border);
        }

        .adm-sidebar-footer {
            padding: .75rem 1rem;
            border-top: 1px solid var(--adm-border);
        }

        .adm-user-row {
            display: flex;
            align-items: center;
            gap: .65rem;
            padding: .45rem .6rem;
            border-radius: 4px;
            transition: background .15s;
            cursor: default;
        }
        .adm-user-row:hover { background: var(--adm-bg3); }
        .adm-avatar {
            width: 28px; height: 28px;
            border-radius: 50%;
            background: var(--adm-accent);
            display: flex; align-items: center; justify-content: center;
            font-size: .65rem;
            font-weight: 700;
            color: var(--adm-bg);
            flex-shrink: 0;
        }
        .adm-user-name { font-size: .78rem; font-weight: 500; color: var(--adm-text); }
        .adm-user-role { font-size: .6rem; color: var(--adm-text3); font-family: 'JetBrains Mono', monospace; }

        .adm-main {
            margin-left: var(--adm-sidebar);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .adm-topbar {
            background: var(--adm-bg2);
            border-bottom: 1px solid var(--adm-border);
            padding: .875rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 99;
            transition: background .3s;
        }

        .adm-breadcrumb {
            display: flex;
            align-items: center;
            gap: .5rem;
            font-size: .78rem;
            color: var(--adm-text2);
        }
        .adm-breadcrumb .sep { color: var(--adm-text3); }
        .adm-breadcrumb .current { color: var(--adm-text); font-weight: 500; }

        .adm-topbar-actions { display: flex; align-items: center; gap: .5rem; }

        .adm-icon-btn {
            width: 32px; height: 32px;
            display: flex; align-items: center; justify-content: center;
            border: 1px solid var(--adm-border);
            border-radius: 6px;
            background: transparent;
            color: var(--adm-text2);
            cursor: pointer;
            transition: all .15s;
            font-size: .85rem;
        }
        .adm-icon-btn:hover { border-color: var(--adm-accent); color: var(--adm-accent); background: rgba(197,165,114,0.06); }

        .adm-content { padding: 1.5rem; flex: 1; }

        .adm-page-header {
            display: flex;
            align-items: flex-start;
            justify-content: space-between;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
            gap: 1rem;
        }
        .adm-page-title {
            font-size: 1.15rem;
            font-weight: 600;
            color: var(--adm-text);
            margin-bottom: .2rem;
        }
        .adm-page-desc {
            font-size: .75rem;
            color: var(--adm-text2);
            font-family: 'JetBrains Mono', monospace;
        }

        .adm-btn {
            display: inline-flex;
            align-items: center;
            gap: .45rem;
            padding: .45rem .9rem;
            border-radius: 6px;
            font-size: .78rem;
            font-weight: 500;
            cursor: pointer;
            transition: all .15s;
            border: 1px solid transparent;
            text-decoration: none;
            font-family: 'Inter', sans-serif;
        }
        .adm-btn-primary { background: var(--adm-accent); color: var(--adm-bg); border-color: var(--adm-accent); }
        .adm-btn-primary:hover { background: var(--adm-accent2); color: var(--adm-bg); border-color: var(--adm-accent2); }
        .adm-btn-secondary { background: var(--adm-bg3); color: var(--adm-text); border-color: var(--adm-border); }
        .adm-btn-secondary:hover { background: var(--adm-bg4); border-color: var(--adm-border2); }
        .adm-btn-danger { background: rgba(248,81,73,0.1); color: var(--adm-red); border-color: rgba(248,81,73,0.3); }
        .adm-btn-danger:hover { background: rgba(248,81,73,0.18); }
        .adm-btn-ghost { background: transparent; color: var(--adm-text2); border-color: var(--adm-border); }
        .adm-btn-ghost:hover { color: var(--adm-text); background: var(--adm-bg3); }

        .adm-stats { display: grid; grid-template-columns: repeat(4,1fr); gap: 1rem; margin-bottom: 1.5rem; }
        .adm-stat {
            background: var(--adm-bg2);
            border: 1px solid var(--adm-border);
            border-radius: 8px;
            padding: 1.1rem 1.25rem;
            display: flex;
            align-items: flex-start;
            gap: .85rem;
            transition: border-color .2s;
        }
        .adm-stat:hover { border-color: rgba(197,165,114,0.3); }
        .adm-stat-icon {
            width: 36px; height: 36px;
            border-radius: 6px;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem;
            flex-shrink: 0;
        }
        .adm-stat-num { font-size: 1.5rem; font-weight: 700; line-height: 1; margin-bottom: .2rem; }
        .adm-stat-lbl { font-size: .72rem; color: var(--adm-text2); }
        .adm-stat-trend { font-size: .65rem; font-family: 'JetBrains Mono', monospace; color: var(--adm-text3); margin-top: .15rem; }

        .adm-card {
            background: var(--adm-bg2);
            border: 1px solid var(--adm-border);
            border-radius: 8px;
            overflow: hidden;
            transition: background .3s;
        }
        .adm-card-header {
            padding: .875rem 1.25rem;
            border-bottom: 1px solid var(--adm-border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 1rem;
            flex-wrap: wrap;
        }
        .adm-card-title {
            font-size: .85rem;
            font-weight: 600;
            color: var(--adm-text);
            display: flex;
            align-items: center;
            gap: .5rem;
        }
        .adm-card-title i { color: var(--adm-accent); }

        table.adm-table { width: 100%; border-collapse: collapse; }
        table.adm-table th {
            padding: .65rem 1.1rem;
            font-size: .68rem;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: .08em;
            color: var(--adm-text3);
            border-bottom: 1px solid var(--adm-border);
            text-align: left;
            font-family: 'JetBrains Mono', monospace;
            background: var(--adm-bg3);
        }
        table.adm-table td {
            padding: .75rem 1.1rem;
            font-size: .8rem;
            border-bottom: 1px solid var(--adm-border2);
            color: var(--adm-text2);
            vertical-align: middle;
        }
        table.adm-table tbody tr:last-child td { border-bottom: none; }
        table.adm-table tbody tr:hover td { background: rgba(197,165,114,0.03); color: var(--adm-text); }
        .adm-td-primary { font-weight: 500; color: var(--adm-text) !important; }

        .adm-badge {
            display: inline-flex; align-items: center; gap: .3rem;
            padding: .18rem .55rem; border-radius: 999px;
            font-size: .65rem; font-weight: 500;
            font-family: 'JetBrains Mono', monospace;
            border: 1px solid transparent;
        }
        .adm-badge-green { background: rgba(63,185,80,0.1); color: var(--adm-green); border-color: rgba(63,185,80,0.25); }
        .adm-badge-yellow { background: rgba(210,153,34,0.12); color: var(--adm-yellow); border-color: rgba(210,153,34,0.25); }
        .adm-badge-red { background: rgba(248,81,73,0.1); color: var(--adm-red); border-color: rgba(248,81,73,0.25); }
        .adm-badge-blue { background: rgba(56,139,253,0.1); color: var(--adm-blue); border-color: rgba(56,139,253,0.25); }
        .adm-badge-gold { background: rgba(197,165,114,0.12); color: var(--adm-accent); border-color: rgba(197,165,114,0.25); }

        .adm-input {
            background: var(--adm-bg3);
            border: 1px solid var(--adm-border);
            border-radius: 6px;
            padding: .5rem .75rem;
            color: var(--adm-text);
            font-family: 'Inter', sans-serif;
            font-size: .8rem;
            outline: none;
            transition: border-color .15s;
            width: 100%;
        }
        .adm-input:focus { border-color: var(--adm-accent); background: rgba(197,165,114,0.04); }
        .adm-input::placeholder { color: var(--adm-text3); }

        .adm-label {
            display: block;
            font-size: .72rem;
            font-weight: 500;
            color: var(--adm-text2);
            margin-bottom: .35rem;
        }

        .adm-form-group { margin-bottom: 1rem; }

        .adm-alert {
            padding: .65rem .9rem;
            border-radius: 6px;
            font-size: .78rem;
            display: flex;
            align-items: center;
            gap: .5rem;
            margin-bottom: 1rem;
        }
        .adm-alert.success { background: rgba(63,185,80,0.08); border: 1px solid rgba(63,185,80,0.25); color: var(--adm-green); }
        .adm-alert.danger { background: rgba(248,81,73,0.08); border: 1px solid rgba(248,81,73,0.25); color: var(--adm-red); }
        .adm-alert.warning { background: rgba(210,153,34,0.08); border: 1px solid rgba(210,153,34,0.25); color: var(--adm-yellow); }

        .adm-field-error { font-size: .68rem; color: var(--adm-red); margin-top: .25rem; font-family: 'JetBrains Mono', monospace; }

        .adm-empty { text-align: center; padding: 3rem; color: var(--adm-text3); }
        .adm-empty i { font-size: 2rem; margin-bottom: .75rem; display: block; }
        .adm-empty p { font-size: .8rem; }

        @media (max-width: 900px) {
            .adm-sidebar { transform: translateX(-100%); }
            .adm-main { margin-left: 0; }
            .adm-stats { grid-template-columns: 1fr 1fr; }
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

<aside class="adm-sidebar">
    <div class="adm-sidebar-header">
        <div class="adm-logo-mark">EA</div>
        <div>
            <div class="adm-logo-text">EventApp</div>
            <div class="adm-logo-sub">Administration</div>
        </div>
    </div>

    <nav class="adm-nav">
        <div class="adm-nav-section">Tableau de bord</div>
        <a href="{{ path('admin_dashboard') }}"
           class="adm-nav-item {% if app.request.attributes.get('_route') == 'admin_dashboard' %}active{% endif %}">
            <i class="bi bi-grid-1x2"></i> Vue d'ensemble
        </a>

        <div class="adm-nav-section" style="margin-top:.5rem;">Gestion</div>
        <a href="{{ path('admin_event_index') }}"
           class="adm-nav-item {% if app.request.attributes.get('_route') starts with 'admin_event' %}active{% endif %}">
            <i class="bi bi-calendar3"></i> Événements
        </a>
        <a href="{{ path('admin_event_new') }}" class="adm-nav-item">
            <i class="bi bi-plus-circle"></i> Nouvel événement
        </a>

        <div class="adm-nav-section" style="margin-top:.5rem;">Accès</div>
        <a href="{{ path('event_index') }}" class="adm-nav-item" target="_blank">
            <i class="bi bi-box-arrow-up-right"></i> Voir le site
        </a>
    </nav>

    <div class="adm-sidebar-footer">
        <div class="adm-user-row">
            <div class="adm-avatar">AD</div>
            <div>
                <div class="adm-user-name">Administrateur</div>
                <div class="adm-user-role">ROLE_ADMIN</div>
            </div>
        </div>
        <a href="{{ path('admin_logout') }}" class="adm-nav-item" style="margin-top:.25rem;color:var(--adm-red);">
    <i class="bi bi-box-arrow-right"></i> Déconnexion
</a>
    </div>
</aside>

<div class="adm-main">
    <header class="adm-topbar">
        <div class="adm-breadcrumb">
            <span>Admin</span>
            <span class="sep">/</span>
            <span class="current">{% block page_title %}Dashboard{% endblock %}</span>
        </div>
        <div class="adm-topbar-actions">
            <button class="adm-icon-btn" id="themeToggle" title="Thème">
                <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
            </button>
            <a href="{{ path('event_index') }}" class="adm-icon-btn" title="Voir le site" target="_blank">
                <i class="bi bi-box-arrow-up-right"></i>
            </a>
        </div>
    </header>

    {% for type, messages in app.flashes %}
        {% for message in messages %}
        <div style="padding:.5rem 1.5rem 0;">
            <div class="adm-alert {{ type == 'success' ? 'success' : (type == 'warning' ? 'warning' : 'danger') }}">
                <i class="bi bi-{{ type == 'success' ? 'check-circle' : 'exclamation-circle' }}"></i>
                {{ message }}
            </div>
        </div>
        {% endfor %}
    {% endfor %}

    <main class="adm-content">
        {% block content %}{% endblock %}
    </main>
</div>

<script>
(function() {
    const html = document.documentElement;
    const btn = document.getElementById('themeToggle');
    const icon = document.getElementById('themeIcon');
    let dark = localStorage.getItem('adm-theme') !== 'light';
    function apply() {
        html.setAttribute('data-theme', dark ? 'dark' : 'light');
        icon.className = dark ? 'bi bi-moon-stars-fill' : 'bi bi-sun-fill';
        localStorage.setItem('adm-theme', dark ? 'dark' : 'light');
    }
    apply();
    btn?.addEventListener('click', () => { dark = !dark; apply(); });
})();
</script>
{% block javascripts %}{% endblock %}
</body>
</html>
