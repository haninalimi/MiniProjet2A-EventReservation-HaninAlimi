<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Admin{% endblock %} — EventApp</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-primary: #0a0a0f;
            --bg-secondary: #111118;
            --bg-card: #16161f;
            --bg-card-hover: #1e1e2a;
            --accent-purple: #7c3aed;
            --accent-violet: #8b5cf6;
            --accent-pink: #ec4899;
            --accent-gradient: linear-gradient(135deg, #7c3aed, #ec4899);
            --text-primary: #f1f0ff;
            --text-secondary: #9991b8;
            --text-muted: #5c5780;
            --border-color: rgba(124,58,237,0.2);
            --border-hover: rgba(124,58,237,0.5);
            --sidebar-width: 240px;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            font-family: 'Inter', sans-serif;
            background: var(--bg-primary);
            color: var(--text-primary);
            min-height: 100vh;
            display: flex;
        }

        .admin-sidebar {
            width: var(--sidebar-width);
            background: var(--bg-secondary);
            border-right: 1px solid var(--border-color);
            min-height: 100vh;
            position: fixed;
            top: 0; left: 0;
            display: flex;
            flex-direction: column;
            z-index: 100;
        }

        .sidebar-brand {
            padding: 1.5rem;
            border-bottom: 1px solid var(--border-color);
        }

        .sidebar-brand-text {
            font-size: 1.3rem;
            font-weight: 800;
            background: var(--accent-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .sidebar-brand-sub {
            font-size: .7rem;
            color: var(--text-muted);
            margin-top: 2px;
        }

        .sidebar-nav { padding: 1rem .75rem; flex: 1; }

        .sidebar-section {
            font-size: .65rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: .1em;
            padding: .75rem .75rem .35rem;
        }

        .sidebar-link {
            display: flex;
            align-items: center;
            gap: .75rem;
            padding: .65rem .75rem;
            border-radius: 10px;
            color: var(--text-secondary);
            text-decoration: none;
            font-size: .875rem;
            font-weight: 500;
            transition: all .2s;
            margin-bottom: 2px;
        }

        .sidebar-link:hover {
            background: rgba(124,58,237,0.1);
            color: var(--text-primary);
        }

        .sidebar-link.active {
            background: rgba(124,58,237,0.15);
            color: var(--accent-violet);
            border: 1px solid rgba(124,58,237,0.2);
        }

        .sidebar-link i { font-size: 1rem; width: 18px; }

        .sidebar-footer {
            padding: 1rem .75rem;
            border-top: 1px solid var(--border-color);
        }

        .admin-main {
            margin-left: var(--sidebar-width);
            flex: 1;
            display: flex;
            flex-direction: column;
            min-height: 100vh;
        }

        .admin-topbar {
            background: rgba(10,10,15,0.8);
            backdrop-filter: blur(20px);
            border-bottom: 1px solid var(--border-color);
            padding: 1rem 1.5rem;
            display: flex;
            align-items: center;
            justify-content: space-between;
            position: sticky;
            top: 0;
            z-index: 99;
        }

        .admin-content { padding: 2rem 1.5rem; flex: 1; }

        .admin-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            overflow: hidden;
        }

        .admin-card-header {
            padding: 1rem 1.25rem;
            border-bottom: 1px solid var(--border-color);
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            border-radius: 16px;
            padding: 1.5rem;
            transition: all .2s;
        }

        .stat-card:hover {
            border-color: var(--border-hover);
            transform: translateY(-2px);
        }

        .stat-icon {
            width: 48px; height: 48px;
            border-radius: 12px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.3rem;
            margin-bottom: 1rem;
        }

        .admin-table { width: 100%; border-collapse: collapse; }
        .admin-table th {
            padding: .75rem 1rem;
            font-size: .75rem;
            font-weight: 600;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: .05em;
            border-bottom: 1px solid var(--border-color);
            text-align: left;
        }
        .admin-table td {
            padding: .875rem 1rem;
            font-size: .875rem;
            border-bottom: 1px solid rgba(124,58,237,0.08);
            color: var(--text-secondary);
        }
        .admin-table tbody tr:hover td {
            background: rgba(124,58,237,0.04);
            color: var(--text-primary);
        }
        .admin-table tbody tr:last-child td { border-bottom: none; }

        .btn-admin-primary {
            background: var(--accent-gradient);
            border: none;
            color: #fff;
            font-weight: 600;
            font-size: .875rem;
            padding: .55rem 1.25rem;
            border-radius: 10px;
            cursor: pointer;
            transition: all .2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
        }
        .btn-admin-primary:hover {
            opacity: .9;
            transform: translateY(-1px);
            color: #fff;
            box-shadow: 0 6px 20px rgba(124,58,237,0.4);
        }

        .btn-admin-ghost {
            background: transparent;
            border: 1px solid var(--border-color);
            color: var(--text-secondary);
            font-weight: 500;
            font-size: .875rem;
            padding: .55rem 1.25rem;
            border-radius: 10px;
            cursor: pointer;
            transition: all .2s;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: .4rem;
        }
        .btn-admin-ghost:hover {
            border-color: var(--border-hover);
            color: var(--text-primary);
        }

        .btn-icon {
            width: 32px; height: 32px;
            border-radius: 8px;
            border: 1px solid var(--border-color);
            background: transparent;
            color: var(--text-secondary);
            display: inline-flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            transition: all .2s;
            text-decoration: none;
            font-size: .875rem;
        }
        .btn-icon:hover { color: var(--text-primary); border-color: var(--border-hover); }
        .btn-icon.danger:hover { background: rgba(239,68,68,0.1); border-color: rgba(239,68,68,0.4); color: #f87171; }
        .btn-icon.warning:hover { background: rgba(245,158,11,0.1); border-color: rgba(245,158,11,0.4); color: #fbbf24; }

        .admin-input {
            width: 100%;
            background: rgba(255,255,255,0.04);
            border: 1px solid var(--border-color);
            color: var(--text-primary);
            border-radius: 10px;
            padding: .65rem 1rem;
            font-size: .875rem;
            transition: all .2s;
            font-family: 'Inter', sans-serif;
        }
        .admin-input:focus {
            outline: none;
            border-color: var(--accent-purple);
            background: rgba(124,58,237,0.06);
            box-shadow: 0 0 0 3px rgba(124,58,237,0.1);
        }
        .admin-input::placeholder { color: var(--text-muted); }

        .admin-label {
            display: block;
            font-size: .8rem;
            font-weight: 500;
            color: var(--text-secondary);
            margin-bottom: .4rem;
        }

        .admin-form-group { margin-bottom: 1.25rem; }

        .badge-admin {
            font-size: .7rem;
            font-weight: 600;
            padding: .25rem .65rem;
            border-radius: 20px;
        }
        .badge-success { background: rgba(16,185,129,0.15); color: #10b981; border: 1px solid rgba(16,185,129,0.2); }
        .badge-warning { background: rgba(245,158,11,0.15); color: #f59e0b; border: 1px solid rgba(245,158,11,0.2); }
        .badge-info    { background: rgba(124,58,237,0.15); color: var(--accent-violet); border: 1px solid var(--border-color); }

        .admin-alert {
            padding: .875rem 1rem;
            border-radius: 10px;
            font-size: .875rem;
            margin-bottom: 1.5rem;
            display: flex;
            align-items: center;
            gap: .6rem;
        }
        .admin-alert.success { background: rgba(16,185,129,0.1); border: 1px solid rgba(16,185,129,0.25); color: #6ee7b7; }
        .admin-alert.danger  { background: rgba(239,68,68,0.1);  border: 1px solid rgba(239,68,68,0.25);  color: #fca5a5; }

        .page-title {
            font-size: 1.4rem;
            font-weight: 700;
            color: var(--text-primary);
        }

        .text-gradient {
            background: var(--accent-gradient);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        ::-webkit-scrollbar { width: 4px; }
        ::-webkit-scrollbar-track { background: var(--bg-primary); }
        ::-webkit-scrollbar-thumb { background: var(--accent-purple); border-radius: 2px; }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

<aside class="admin-sidebar">
    <div class="sidebar-brand">
        <div class="sidebar-brand-text">◈ EventApp</div>
        <div class="sidebar-brand-sub">Panneau d'administration</div>
    </div>

    <nav class="sidebar-nav">
        <div class="sidebar-section">Navigation</div>

        <a href="{{ path('admin_dashboard') }}"
           class="sidebar-link {{ app.request.attributes.get('_route') == 'admin_dashboard' ? 'active' : '' }}">
            <i class="bi bi-speedometer2"></i> Dashboard
        </a>

        <a href="{{ path('admin_event_index') }}"
           class="sidebar-link {{ app.request.attributes.get('_route') starts with 'admin_event' ? 'active' : '' }}">
            <i class="bi bi-calendar3"></i> Événements
        </a>

        <div class="sidebar-section" style="margin-top:.5rem;">Accès rapide</div>

        <a href="{{ path('admin_event_new') }}" class="sidebar-link">
            <i class="bi bi-plus-circle"></i> Nouvel événement
        </a>

        <a href="{{ path('event_index') }}" class="sidebar-link" target="_blank">
            <i class="bi bi-box-arrow-up-right"></i> Voir le site
        </a>
    </nav>

    <div class="sidebar-footer">
        <a href="{{ path('app_login') }}" class="sidebar-link" style="color:#f87171;">
            <i class="bi bi-box-arrow-right"></i> Déconnexion
        </a>
    </div>
</aside>

<div class="admin-main">

    <header class="admin-topbar">
        <div class="page-title">{% block page_title %}Dashboard{% endblock %}</div>
        <div style="display:flex; align-items:center; gap:1rem;">
            <span style="font-size:.8rem; color:var(--text-muted);">
                <i class="bi bi-shield-check me-1" style="color:var(--accent-violet);"></i>
                Administrateur
            </span>
        </div>
    </header>

    <main class="admin-content">
        {% for type, messages in app.flashes %}
            {% for message in messages %}
            <div class="admin-alert {{ type }}">
                <i class="bi bi-{{ type == 'success' ? 'check-circle' : 'exclamation-circle' }}"></i>
                {{ message }}
            </div>
            {% endfor %}
        {% endfor %}

        {% block content %}{% endblock %}
    </main>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
{% block javascripts %}{% endblock %}
</body>
</html>