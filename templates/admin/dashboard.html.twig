{% extends 'admin/base_admin.html.twig' %}
{% block title %}Dashboard{% endblock %}
{% block page_title %}Vue d'ensemble{% endblock %}

{% block content %}

<div class="adm-page-header">
    <div>
        <div class="adm-page-title">Tableau de bord</div>
        <div class="adm-page-desc">{{ "now"|date('d/m/Y') }} · EventApp Production</div>
    </div>
    <a href="{{ path('admin_event_index') }}" class="adm-btn adm-btn-primary">
        <i class="bi bi-plus-lg"></i> Nouvel événement
    </a>
</div>

<div class="adm-stats">

    <div class="adm-stat" style="--stat-accent:var(--c-amber)">
        <div class="adm-stat-header">
            <div class="adm-stat-icon"><i class="bi bi-calendar3"></i></div>
            <span class="adm-stat-trend">TOTAL</span>
        </div>
        <div class="adm-stat-num">{{ totalEvents }}</div>
        <div class="adm-stat-lbl">Événements</div>
        <div class="adm-stat-sub">dans le catalogue</div>
    </div>

    <div class="adm-stat" style="--stat-accent:var(--c-blue)">
        <div class="adm-stat-header">
            <div class="adm-stat-icon"><i class="bi bi-people-fill"></i></div>
            <span class="adm-stat-trend">ALL TIME</span>
        </div>
        <div class="adm-stat-num">{{ totalReservations }}</div>
        <div class="adm-stat-lbl">Réservations</div>
        <div class="adm-stat-sub">confirmées</div>
    </div>

    <div class="adm-stat" style="--stat-accent:var(--c-green)">
        <div class="adm-stat-header">
            <div class="adm-stat-icon"><i class="bi bi-shield-fill-check"></i></div>
            <span class="adm-stat-trend">ACTIF</span>
        </div>
        <div class="adm-stat-num" style="font-size:1.4rem;">JWT</div>
        <div class="adm-stat-lbl">Sécurité</div>
        <div class="adm-stat-sub">+ Passkeys FIDO2</div>
    </div>

    <div class="adm-stat" style="--stat-accent:var(--c-purple)">
        <div class="adm-stat-header">
            <div class="adm-stat-icon"><i class="bi bi-activity"></i></div>
            <span class="adm-stat-trend">LIVE</span>
        </div>
        <div class="adm-stat-num" style="font-size:1.1rem;">7.4.7</div>
        <div class="adm-stat-lbl">Symfony</div>
        <div class="adm-stat-sub">PHP 8.3 · PostgreSQL 15</div>
    </div>

</div>

<div class="adm-card">
    <div class="adm-card-header">
        <div class="adm-card-title">
            <i class="bi bi-clock-history"></i>
            Derniers événements
        </div>
        <a href="{{ path('admin_event_index') }}" class="adm-btn adm-btn-ghost">
            Voir tout <i class="bi bi-arrow-right"></i>
        </a>
    </div>
    <table class="adm-table">
        <thead>
            <tr>
                <th>ID</th>
                <th>Titre</th>
                <th>Date</th>
                <th>Lieu</th>
                <th>Places</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for event in latestEvents %}
            <tr>
                <td class="adm-td-mono u-muted">#{{ event.id }}</td>
                <td class="adm-td-main">{{ event.title }}</td>
                <td class="adm-td-mono">{{ event.date|date('d/m/Y') }}</td>
                <td>{{ event.location }}</td>
                <td>
                    <span class="adm-badge adm-badge-amber">{{ event.seats }}</span>
                </td>
                <td>
                    <div style="display:flex;gap:.3rem;">
                        <a href="{{ path('admin_event_edit', {id: event.id}) }}"
                           class="adm-btn adm-btn-secondary"
                           style="padding:.28rem .5rem;" title="Modifier">
                            <i class="bi bi-pencil"></i>
                        </a>
                        <a href="{{ path('admin_event_reservations', {id: event.id}) }}"
                           class="adm-btn adm-btn-ghost"
                           style="padding:.28rem .5rem;" title="Réservations">
                            <i class="bi bi-people"></i>
                        </a>
                    </div>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="6">
                    <div class="adm-empty">
                        <i class="bi bi-calendar-x adm-empty-icon"></i>
                        <div class="adm-empty-title">Aucun événement</div>
                        <div class="adm-empty-desc">Le catalogue est vide</div>
                        <a href="{{ path('admin_event_index') }}" class="adm-btn adm-btn-primary">
                            <i class="bi bi-plus-lg"></i> Créer le premier
                        </a>
                    </div>
                </td>
            </tr>
        {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
