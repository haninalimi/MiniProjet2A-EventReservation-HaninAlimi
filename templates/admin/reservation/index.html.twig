{% extends 'admin/base_admin.html.twig' %}
{% block title %}Réservations — {{ event.title }}{% endblock %}
{% block page_title %}Réservations{% endblock %}

{% block content %}

<div class="adm-page-header">
    <div>
        <div class="adm-page-title">Réservations</div>
        <div class="adm-page-desc">{{ event.title }} · {{ reservations|length }} réservation(s)</div>
    </div>
    <a href="{{ path('admin_event_index') }}" class="adm-btn adm-btn-ghost">
        <i class="bi bi-arrow-left"></i> Retour aux événements
    </a>
</div>

<div style="display:grid;grid-template-columns:repeat(3,1fr);gap:1rem;margin-bottom:1.5rem;">
    <div class="adm-stat">
        <div class="adm-stat-icon" style="background:rgba(197,165,114,0.1);">
            <i class="bi bi-calendar3" style="color:var(--adm-accent);"></i>
        </div>
        <div>
            <div class="adm-stat-num" style="color:var(--adm-accent);font-size:1rem;">{{ event.date|date('d/m/Y') }}</div>
            <div class="adm-stat-lbl">Date de l'événement</div>
        </div>
    </div>
    <div class="adm-stat">
        <div class="adm-stat-icon" style="background:rgba(56,139,253,0.1);">
            <i class="bi bi-people" style="color:var(--adm-blue);"></i>
        </div>
        <div>
            <div class="adm-stat-num" style="color:var(--adm-blue);">{{ reservations|length }} / {{ event.seats }}</div>
            <div class="adm-stat-lbl">Places réservées</div>
        </div>
    </div>
    <div class="adm-stat">
        <div class="adm-stat-icon" style="background:rgba(63,185,80,0.1);">
            <i class="bi bi-geo-alt" style="color:var(--adm-green);"></i>
        </div>
        <div>
            <div class="adm-stat-num" style="color:var(--adm-green);font-size:.9rem;">{{ event.location }}</div>
            <div class="adm-stat-lbl">Lieu</div>
        </div>
    </div>
</div>

<div class="adm-card">
    <div class="adm-card-header">
        <div class="adm-card-title">
            <i class="bi bi-list-ul"></i> Liste des participants
        </div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:.65rem;color:var(--adm-text3);">
            {{ reservations|length }} participant(s)
        </div>
    </div>
    <table class="adm-table">
        <thead>
            <tr>
                <th>#</th>
                <th>Nom</th>
                <th>Email</th>
                <th>Téléphone</th>
                <th>Date réservation</th>
                <th>Statut</th>
            </tr>
        </thead>
        <tbody>
            {% for reservation in reservations %}
            <tr>
                <td><span style="font-family:'JetBrains Mono',monospace;color:var(--adm-text3);">{{ loop.index }}</span></td>
                <td class="adm-td-primary">{{ reservation.name }}</td>
                <td style="font-family:'JetBrains Mono',monospace;font-size:.72rem;">{{ reservation.email }}</td>
                <td>{{ reservation.phone ?? '—' }}</td>
                <td style="font-family:'JetBrains Mono',monospace;font-size:.72rem;">
                    {{ reservation.createdAt ? reservation.createdAt|date('d/m/Y H:i') : '—' }}
                </td>
                <td><span class="adm-badge adm-badge-green"><i class="bi bi-check"></i> Confirmée</span></td>
            </tr>
            {% else %}
            <tr>
                <td colspan="6" class="adm-empty">
                    <i class="bi bi-inbox"></i>
                    <p>Aucune réservation pour cet événement</p>
                </td>
            </tr>
            {% endfor %}
        </tbody>
    </table>
</div>

{% endblock %}
