{% extends 'admin/base_admin.html.twig' %}
{% block title %}Réservations — {{ event.title }}{% endblock %}
{% block page_title %}
    <span class="text-gradient">Réservations</span>
{% endblock %}

{% block content %}

<div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:1.5rem;">
    <div>
        <div style="font-weight:700; font-size:1.1rem;">{{ event.title }}</div>
        <div style="color:var(--text-muted); font-size:.8rem; margin-top:.25rem;">
            <i class="bi bi-calendar3 me-1"></i>{{ event.date|date('d/m/Y à H:i') }}
            <span class="mx-2">·</span>
            <i class="bi bi-geo-alt me-1"></i>{{ event.location }}
        </div>
    </div>
    <div style="display:flex; gap:.75rem; align-items:center;">
        <span class="badge-admin badge-success">
            <i class="bi bi-people me-1"></i>{{ reservations|length }} réservation(s)
        </span>
        <a href="{{ path('admin_event_index') }}" class="btn-admin-ghost">
            <i class="bi bi-arrow-left"></i> Retour
        </a>
    </div>
</div>

<div class="admin-card">
    <div style="overflow-x:auto;">
        <table class="admin-table">
            <thead>
                <tr>
                    <th>#</th>
                    <th>Nom</th>
                    <th>Email</th>
                    <th>Téléphone</th>
                    <th>Date de réservation</th>
                </tr>
            </thead>
            <tbody>
                {% for reservation in reservations %}
                <tr>
                    <td style="color:var(--text-muted);">{{ reservation.id }}</td>
                    <td style="font-weight:600; color:var(--text-primary);">
                        {{ reservation.name }}
                    </td>
                    <td>{{ reservation.email }}</td>
                    <td>{{ reservation.phone ?? '—' }}</td>
                    <td>
                        <span class="badge-admin badge-info">
                            {{ reservation.createdAt|date('d/m/Y H:i') }}
                        </span>
                    </td>
                </tr>
                {% else %}
                <tr>
                    <td colspan="5" style="text-align:center; padding:3rem; color:var(--text-muted);">
                        Aucune réservation pour cet événement.
                    </td>
                </tr>
                {% endfor %}
            </tbody>
        </table>
    </div>
</div>

{% endblock %}
