{% extends 'base.html.twig' %}

{% block title %}Événements — EventApp{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/events.css') }}">
{% endblock %}

{% block body %}

<section class="book-section events-page-hero" data-sec="0">
    <div class="page-hero-eyebrow">Catalogue complet</div>
    <h1 class="page-hero-h1">
        Tous nos <em>événements</em><br>disponibles
    </h1>
    <p class="page-hero-desc">
        Concerts, conférences, workshops, hackathons — réservez votre place en quelques secondes grâce à la technologie Passkey.
    </p>
    <div class="events-stats-bar">
        <div class="esb-item">
            <div class="esb-num">{{ events|length }}</div>
            <div class="esb-lbl">Événements</div>
        </div>
        <div class="esb-item">
            <div class="esb-num">
                {% set ts = 0 %}{% for e in events %}{% set ts = ts + e.seats %}{% endfor %}{{ ts }}
            </div>
            <div class="esb-lbl">Places totales</div>
        </div>
        <div class="esb-item">
            <div class="esb-num">100%</div>
            <div class="esb-lbl">Sécurisé</div>
        </div>
    </div>
</section>

<div class="page-sep" style="background:var(--bg2);">
    <div class="sep-line-full"></div>
    <div class="sep-center" style="background:var(--bg2);">
        <div class="sep-diamond-sm"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-label">Recherche &amp; filtres</div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-sm"></div>
    </div>
</div>

<div class="events-filters">
    <div class="search-lux">
        <i class="bi bi-search"></i>
        <input type="text" class="search-input-lux" id="evSearch"
               placeholder="Rechercher un événement..."
               oninput="filterEvents()">
    </div>
    <div class="filter-pills">
        <button class="filter-pill active" id="f-all" onclick="applyFilter('all')">
            <i class="bi bi-grid-3x3-gap"></i> Tous
        </button>
        <button class="filter-pill" id="f-upcoming" onclick="applyFilter('upcoming')">
            <i class="bi bi-calendar-check"></i> À venir
        </button>
        <button class="filter-pill" id="f-available" onclick="applyFilter('available')">
            <i class="bi bi-people"></i> Places dispo
        </button>
    </div>
</div>

<div class="page-sep">
    <div class="sep-line-full"></div>
    <div class="sep-center">
        <div class="sep-diamond-sm"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-label">Catalogue des événements</div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-sm"></div>
    </div>
</div>

<section class="events-catalog" data-sec="1">
    <div class="catalog-header">
        <div class="catalog-count">
            <span id="visibleCount">{{ events|length }}</span> événement(s) affiché(s)
        </div>
        <a href="{{ path('app_home') }}" style="font-family:'Space Mono',monospace;font-size:.5rem;letter-spacing:.12em;text-transform:uppercase;color:var(--text3);text-decoration:none;display:flex;align-items:center;gap:.4rem;">
            ← Retour à l'accueil
        </a>
    </div>

    <div class="catalog-grid" id="eventsGrid">
        {% if events is empty %}
        <div class="empty-state-lux">
            <div class="empty-icon">◈</div>
            <div class="empty-title">Aucun événement disponible</div>
            <p class="empty-desc">Notre catalogue s'enrichit régulièrement. Revenez bientôt pour découvrir nos prochains événements.</p>
            <a href="{{ path('app_register') }}" class="btn-or">Créer un compte</a>
        </div>
        {% else %}
            {% for event in events %}
            <div class="ev-card reveal-lux event-item"
                 data-title="{{ event.title|lower }}"
                 data-date="{{ event.date|date('Y-m-d') }}"
                 data-seats="{{ event.seats }}">
                <div class="ev-img">
                    {% if event.image %}
                        <img src="{{ asset('uploads/events/' ~ event.image) }}" alt="{{ event.title }}">
                    {% else %}
                        <div class="ev-img-placeholder">✦</div>
                    {% endif %}
                    <div class="ev-badge">
                        <i class="bi bi-people me-1"></i>{{ event.seats }} places
                    </div>
                </div>
                <div class="ev-body">
                    <div class="ev-tag">{{ event.date|date('d/m/Y') }} · {{ event.location }}</div>
                    <div class="ev-title">{{ event.title }}</div>
                    <p class="ev-desc">
                        {{ event.description|slice(0,100) }}{% if event.description|length > 100 %}…{% endif %}
                    </p>
                    <div class="ev-meta">
                        <div class="ev-meta-row">
                            <i class="bi bi-calendar3"></i>
                            <span>{{ event.date|date('d/m/Y à H:i') }}</span>
                        </div>
                        <div class="ev-meta-row">
                            <i class="bi bi-geo-alt"></i>
                            <span>{{ event.location }}</span>
                        </div>
                    </div>
                    <div class="ev-seats">
                        <div class="ev-seats-bar">
<div class="ev-seats-fill" style="width:{% if event.seats * 5 > 100 %}100{% else %}{{ event.seats * 5 }}{% endif %}%;"></div>
                        </div>
                        <div class="ev-seats-count">{{ event.seats }} places</div>
                    </div>
                    <a href="{{ path('event_show', {id: event.id}) }}" class="ev-btn">
                        Voir et réserver →
                    </a>
                </div>
            </div>
            {% endfor %}
        {% endif %}
    </div>
</section>

{% endblock %}

{% block javascripts %}
    {{ parent() }}
    <script src="{{ asset('js/events.js') }}"></script>
{% endblock %}