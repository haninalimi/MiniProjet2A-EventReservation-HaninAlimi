{% extends 'base.html.twig' %}

{% block title %}Événements{% endblock %}

{% block body %}
<div class="hero text-white py-5 mb-5">
    <div class="container text-center">
        <h1 class="display-4 fw-bold">
            <i class="bi bi-calendar-event"></i> Événements à venir
        </h1>
        <p class="lead">Découvrez et réservez vos places en quelques clics</p>
    </div>
</div>

<div class="container mb-5">
    {% if events is empty %}
        <div class="text-center py-5">
            <i class="bi bi-calendar-x display-1 text-muted"></i>
            <p class="lead text-muted mt-3">Aucun événement disponible pour le moment.</p>
        </div>
    {% else %}
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            {% for event in events %}
            <div class="col">
                <div class="card h-100 shadow-sm">
                    {% if event.image %}
                        <img src="{{ asset('uploads/events/' ~ event.image) }}"
                             class="card-img-top" alt="{{ event.title }}"
                             style="height:200px;object-fit:cover">
                    {% else %}
                        <div class="card-img-top bg-secondary d-flex align-items-center justify-content-center"
                             style="height:200px">
                            <i class="bi bi-image text-white display-4"></i>
                        </div>
                    {% endif %}
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title">{{ event.title }}</h5>
                        <p class="card-text text-muted small">
                            {{ event.description|slice(0, 120) }}{% if event.description|length > 120 %}...{% endif %}
                        </p>
                        <div class="mt-auto">
                            <p class="mb-1 small">
                                <i class="bi bi-calendar3 text-primary"></i>
                                {{ event.date|date('d/m/Y H:i') }}
                            </p>
                            <p class="mb-2 small">
                                <i class="bi bi-geo-alt text-danger"></i>
                                {{ event.location }}
                            </p>
                            <span class="badge bg-success badge-seats">
                                <i class="bi bi-people"></i> {{ event.seats }} places
                            </span>
                        </div>
                    </div>
                    <div class="card-footer bg-transparent">
                        <a href="{{ path('event_show', {id: event.id}) }}"
                           class="btn btn-primary w-100">
                            <i class="bi bi-eye"></i> Voir les détails
                        </a>
                    </div>
                </div>
            </div>
            {% endfor %}
        </div>
    {% endif %}
</div>
{% endblock %}