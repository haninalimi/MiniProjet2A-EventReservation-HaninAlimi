{% extends 'base.html.twig' %}

{% block title %}{{ event.title }}{% endblock %}

{% block body %}
<div class="container py-5">
    <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
            <li class="breadcrumb-item">
                <a href="{{ path('event_index') }}">Événements</a>
            </li>
            <li class="breadcrumb-item active">{{ event.title }}</li>
        </ol>
    </nav>

    <div class="row g-4">
        <div class="col-lg-8">
            {% if event.image %}
                <img src="{{ asset('uploads/events/' ~ event.image) }}"
                     class="img-fluid rounded mb-4 w-100"
                     alt="{{ event.title }}"
                     style="max-height:400px;object-fit:cover">
            {% endif %}
            <h1 class="fw-bold">{{ event.title }}</h1>
            <p class="lead text-muted">{{ event.description }}</p>
        </div>

        <div class="col-lg-4">
            <div class="card shadow-sm sticky-top" style="top:80px">
                <div class="card-body">
                    <h5 class="card-title mb-4">
                        <i class="bi bi-info-circle text-primary"></i> Informations
                    </h5>
                    <ul class="list-unstyled">
                        <li class="mb-3">
                            <i class="bi bi-calendar3 text-primary me-2"></i>
                            <strong>Date :</strong><br>
                            <span class="ms-4">{{ event.date|date('d/m/Y à H:i') }}</span>
                        </li>
                        <li class="mb-3">
                            <i class="bi bi-geo-alt text-danger me-2"></i>
                            <strong>Lieu :</strong><br>
                            <span class="ms-4">{{ event.location }}</span>
                        </li>
                        <li class="mb-3">
                            <i class="bi bi-people text-success me-2"></i>
                            <strong>Places disponibles :</strong><br>
                            <span class="ms-4">
                                {{ event.seats - reservationCount }} / {{ event.seats }}
                            </span>
                        </li>
                    </ul>

                    {% if event.seats - reservationCount > 0 %}
                        <a href="{{ path('event_reserve', {id: event.id}) }}"
                           class="btn btn-success w-100 btn-lg">
                            <i class="bi bi-ticket-perforated"></i> Réserver ma place
                        </a>
                    {% else %}
                        <button class="btn btn-secondary w-100 btn-lg" disabled>
                            <i class="bi bi-x-circle"></i> Complet
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}