{% extends 'base.html.twig' %}

{% block title %}{{ event.title }} — EventApp{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/show.css') }}">
{% endblock %}

{% block body %}

<section class="show-page">

    <nav class="breadcrumb-lux">
        <a href="{{ path('event_index') }}">← Événements</a>
        <span class="sep">◈</span>
        <span class="current">{{ event.title|slice(0,40) }}{% if event.title|length > 40 %}…{% endif %}</span>
    </nav>

    <div class="show-grid">

        <div>
            {% if event.image %}
            <div class="show-img-wrap">
                <img src="{{ asset('uploads/events/' ~ event.image) }}" alt="{{ event.title }}">
            </div>
            {% else %}
            <div class="show-img-wrap">
                <div class="show-img-placeholder">✦</div>
            </div>
            {% endif %}

            <div class="show-tags">
                <span class="show-tag">
                    <i class="bi bi-calendar3"></i>
                    {{ event.date|date('d/m/Y à H:i') }}
                </span>
                <span class="show-tag">
                    <i class="bi bi-geo-alt"></i>
                    {{ event.location }}
                </span>
                <span class="show-tag">
                    <i class="bi bi-people"></i>
                    {{ event.seats - reservationCount }} / {{ event.seats }} places
                </span>
            </div>

            <h1 class="show-title">{{ event.title }}</h1>

            <div class="show-divider"></div>

            <p class="show-desc">{{ event.description }}</p>
        </div>

        <div>
            <div class="show-card">
                <div class="show-card-header">
                    <div class="show-card-title">Réserver ma place</div>
                    <div class="show-card-sub">Confirmation instantanée</div>
                </div>
                <div class="show-card-body">

                    {% set pct = ((event.seats - reservationCount) / event.seats * 100)|round %}
                    <div class="seats-section">
                        <div class="seats-header">
                            <span class="seats-label">Places disponibles</span>
                            <span class="seats-count">{{ event.seats - reservationCount }} / {{ event.seats }}</span>
                        </div>
                        <div class="seats-track">
                            <div class="seats-fill" style="width:{{ pct }}%;"></div>
                        </div>
                    </div>

                    <div class="info-row">
                        <div class="info-icon"><i class="bi bi-calendar3"></i></div>
                        <div>
                            <div class="info-lbl">Date</div>
                            <div class="info-val">{{ event.date|date('d/m/Y à H:i') }}</div>
                        </div>
                    </div>
                    <div class="info-row">
                        <div class="info-icon"><i class="bi bi-geo-alt"></i></div>
                        <div>
                            <div class="info-lbl">Lieu</div>
                            <div class="info-val">{{ event.location }}</div>
                        </div>
                    </div>
                    <div class="info-row" style="border-bottom:none;">
                        <div class="info-icon"><i class="bi bi-shield-check"></i></div>
                        <div>
                            <div class="info-lbl">Sécurité</div>
                            <div class="info-val">Passkey + JWT</div>
                        </div>
                    </div>

                </div>
                <div class="show-card-cta">
                    {% if event.seats - reservationCount > 0 %}
                        <a href="{{ path('event_reserve', {id: event.id}) }}" class="btn-reserve-full">
                            <i class="bi bi-ticket-perforated"></i> &nbsp; Réserver maintenant
                        </a>
                    {% else %}
                        <div class="btn-complet">
                            <i class="bi bi-x-circle"></i> &nbsp; Événement complet
                        </div>
                    {% endif %}
                </div>
            </div>
        </div>

    </div>
</section>

{% endblock %}