{% extends 'base.html.twig' %}
{% block title %}{{ event.title }}{% endblock %}

{% block body %}
<div class="container py-5">

    <nav style="margin-bottom:2rem;">
        <a href="{{ path('event_index') }}" style="color:var(--text-muted); text-decoration:none; font-size:.875rem;">
            <i class="bi bi-arrow-left me-1"></i> Événements
        </a>
        <span style="color:var(--text-muted); margin:0 .5rem;">/</span>
        <span style="color:var(--text-secondary); font-size:.875rem;">{{ event.title }}</span>
    </nav>

    <div class="row g-5">
        <div class="col-lg-8">
            {% if event.image %}
            <div style="border-radius:20px; overflow:hidden; margin-bottom:2rem; border:1px solid var(--border-color);">
                <img src="{{ asset('uploads/events/' ~ event.image) }}"
                     alt="{{ event.title }}"
                     style="width:100%; max-height:420px; object-fit:cover;">
            </div>
            {% endif %}

            <h1 style="font-size:2.2rem; font-weight:800; margin-bottom:1rem;">
                {{ event.title }}
            </h1>

            <div class="d-flex gap-2 flex-wrap mb-4">
                <span class="badge-glow">
                    <i class="bi bi-calendar3 me-1"></i>
                    {{ event.date|date('d/m/Y à H:i') }}
                </span>
                <span class="badge-glow">
                    <i class="bi bi-geo-alt me-1"></i>
                    {{ event.location }}
                </span>
                <span class="badge-glow">
                    <i class="bi bi-people me-1"></i>
                    {{ event.seats - reservationCount }} / {{ event.seats }} places
                </span>
            </div>

            <hr class="divider-glow">

            <div style="color:var(--text-secondary); line-height:1.8; font-size:1.05rem;">
                {{ event.description }}
            </div>
        </div>

        <div class="col-lg-4">
            <div style="position:sticky; top:90px;">
                <div class="card-dark p-4">
                    <h5 style="font-weight:700; margin-bottom:1.5rem;">
                        <span class="text-gradient">Réserver ma place</span>
                    </h5>

                    {% set pct = ((event.seats - reservationCount) / event.seats * 100)|round %}
                    <div style="margin-bottom:1.5rem;">
                        <div class="d-flex justify-content-between mb-1">
                            <span style="font-size:.8rem; color:var(--text-muted);">Places disponibles</span>
                            <span style="font-size:.8rem; color:var(--accent-violet); font-weight:600;">
                                {{ event.seats - reservationCount }} / {{ event.seats }}
                            </span>
                        </div>
                        <div style="height:6px; background:rgba(255,255,255,.07); border-radius:3px; overflow:hidden;">
                            <div style="height:100%; width:{{ pct }}%; background:var(--accent-gradient); border-radius:3px; transition:width .3s;"></div>
                        </div>
                    </div>

                    <div class="d-flex flex-column gap-2 mb-4">
                        <div style="display:flex; gap:.75rem; align-items:center; padding:.75rem; background:rgba(124,58,237,0.07); border-radius:10px;">
                            <i class="bi bi-calendar3" style="color:var(--accent-purple); font-size:1.1rem;"></i>
                            <div>
                                <div style="font-size:.7rem; color:var(--text-muted);">Date</div>
                                <div style="font-size:.875rem; font-weight:500;">{{ event.date|date('d/m/Y à H:i') }}</div>
                            </div>
                        </div>
                        <div style="display:flex; gap:.75rem; align-items:center; padding:.75rem; background:rgba(236,72,153,0.07); border-radius:10px;">
                            <i class="bi bi-geo-alt" style="color:var(--accent-pink); font-size:1.1rem;"></i>
                            <div>
                                <div style="font-size:.7rem; color:var(--text-muted);">Lieu</div>
                                <div style="font-size:.875rem; font-weight:500;">{{ event.location }}</div>
                            </div>
                        </div>
                    </div>

                    {% if event.seats - reservationCount > 0 %}
                        <a href="{{ path('event_reserve', {id: event.id}) }}" class="btn-glow btn w-100 btn-lg">
                            <i class="bi bi-ticket-perforated me-2"></i> Réserver maintenant
                        </a>
                    {% else %}
                        <button class="btn w-100 btn-lg" disabled
                            style="background:rgba(255,255,255,.05); border:1px solid var(--border-color); color:var(--text-muted); border-radius:12px;">
                            <i class="bi bi-x-circle me-2"></i> Complet
                        </button>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}