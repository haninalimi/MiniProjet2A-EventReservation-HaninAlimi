{% extends 'base.html.twig' %}

{% block title %}Réservation confirmée — EventApp{% endblock %}

{% block stylesheets %}
    {{ parent() }}
    <link rel="stylesheet" href="{{ asset('css/confirmation.css') }}">
{% endblock %}

{% block body %}
<div class="confirm-page">
    <div class="confirm-wrap">

        <div class="confirm-mark">
            <i class="bi bi-check-lg"></i>
        </div>

        <h1 class="confirm-title">Réservation <em>confirmée</em> !</h1>
        <p class="confirm-sub">
            Merci <strong>{{ reservation.name }}</strong>,<br>
            votre place est réservée avec succès.
        </p>

        <div class="confirm-card">
            <div class="confirm-card-title">Détails de la réservation</div>

            <div class="detail-row">
                <div class="detail-icon"><i class="bi bi-calendar-event"></i></div>
                <div>
                    <div class="detail-lbl">Événement</div>
                    <div class="detail-val">{{ reservation.event.title }}</div>
                </div>
            </div>

            <div class="detail-row">
                <div class="detail-icon"><i class="bi bi-clock"></i></div>
                <div>
                    <div class="detail-lbl">Date &amp; heure</div>
                    <div class="detail-val">{{ reservation.event.date|date('d/m/Y à H:i') }}</div>
                </div>
            </div>

            <div class="detail-row">
                <div class="detail-icon"><i class="bi bi-geo-alt"></i></div>
                <div>
                    <div class="detail-lbl">Lieu</div>
                    <div class="detail-val">{{ reservation.event.location }}</div>
                </div>
            </div>

            <div class="detail-row">
                <div class="detail-icon"><i class="bi bi-envelope"></i></div>
                <div>
                    <div class="detail-lbl">Email</div>
                    <div class="detail-val">{{ reservation.email }}</div>
                </div>
            </div>

            {% if reservation.phone %}
            <div class="detail-row">
                <div class="detail-icon"><i class="bi bi-telephone"></i></div>
                <div>
                    <div class="detail-lbl">Téléphone</div>
                    <div class="detail-val">{{ reservation.phone }}</div>
                </div>
            </div>
            {% endif %}

        </div>

        <a href="{{ path('event_index') }}" class="btn-or" style="display:inline-block;width:100%;text-align:center;">
            ← Retour aux événements
        </a>

    </div>
</div>
{% endblock %}