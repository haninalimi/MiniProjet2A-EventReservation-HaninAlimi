{% extends 'base.html.twig' %}
{% block title %}Réserver — {{ event.title }}{% endblock %}

{% block body %}
<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-lg-6">

            <div style="text-align:center; margin-bottom:2.5rem;">
                <div class="badge-glow mb-3 d-inline-block">
                    <span class="glow-dot me-1"></span> Réservation
                </div>
                <h2 style="font-weight:800; font-size:1.8rem;">{{ event.title }}</h2>
                <p style="color:var(--text-muted);">
                    <i class="bi bi-calendar3 me-1"></i> {{ event.date|date('d/m/Y à H:i') }}
                    <span class="mx-2">·</span>
                    <i class="bi bi-geo-alt me-1"></i> {{ event.location }}
                </p>
                <span class="badge-glow">
                    <i class="bi bi-people me-1"></i>
                    {{ availableSeats }} place(s) disponible(s)
                </span>
            </div>

            <div class="card-dark p-4">
                {{ form_start(form, {'attr': {'novalidate': 'novalidate', 'id': 'reservation-form'}}) }}

                <div style="margin-bottom:1.25rem;">
                    <label class="label-dark">{{ form_label(form.name) }}</label>
                    {{ form_widget(form.name, {'attr': {'class': 'input-dark form-control'}}) }}
                    <div style="color:#f87171; font-size:.8rem; margin-top:.3rem;">
                        {{ form_errors(form.name) }}
                    </div>
                </div>

                <div style="margin-bottom:1.25rem;">
                    <label class="label-dark">{{ form_label(form.email) }}</label>
                    {{ form_widget(form.email, {'attr': {'class': 'input-dark form-control'}}) }}
                    <div style="color:#f87171; font-size:.8rem; margin-top:.3rem;">
                        {{ form_errors(form.email) }}
                    </div>
                </div>

                <div style="margin-bottom:1.75rem;">
                    <label class="label-dark">{{ form_label(form.phone) }}</label>
                    {{ form_widget(form.phone, {'attr': {'class': 'input-dark form-control', 'placeholder': '+216 XX XXX XXX'}}) }}
                    <div style="color:#f87171; font-size:.8rem; margin-top:.3rem;">
                        {{ form_errors(form.phone) }}
                    </div>
                </div>

                <button type="submit" class="btn-glow btn w-100 btn-lg">
                    <i class="bi bi-check-circle me-2"></i> Confirmer la réservation
                </button>

                {{ form_end(form) }}

                <div class="text-center mt-3">
                    <a href="{{ path('event_show', {id: event.id}) }}"
                       style="color:var(--text-muted); font-size:.875rem; text-decoration:none;">
                        <i class="bi bi-arrow-left me-1"></i> Retour à l'événement
                    </a>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}