<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}EventApp — L'Art de la Réservation{% endblock %}</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Outfit:wght@200;300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <style>
    
        :root {
            --or: #c5a572;
            --or2: #e5c687;
            --or3: #f5dfa0;
            --or-dim: rgba(197,165,114,0.12);
            --or-border: rgba(197,165,114,0.2);
            --or-border-hover: rgba(197,165,114,0.5);

            --bg: #080808;
            --bg2: #0f0f0f;
            --bg3: #161616;
            --bg4: #1e1e1e;
            --text: #f5f0ea;
            --text2: #a0988a;
            --text3: #5a5248;
            --border: rgba(197,165,114,0.15);
            --shadow: 0 30px 60px rgba(0,0,0,0.7);
            --glass: rgba(15,15,15,0.85);
            --glass-border: rgba(197,165,114,0.18);
        }

        [data-theme="light"] {
            --bg: #f5f0e8;
            --bg2: #ede8df;
            --bg3: #e5dfd4;
            --bg4: #ddd7ca;
            --text: #1a1410;
            --text2: #5a4e3c;
            --text3: #9a8e7a;
            --border: rgba(197,165,114,0.25);
            --shadow: 0 30px 60px rgba(0,0,0,0.12);
            --glass: rgba(245,240,232,0.9);
            --glass-border: rgba(197,165,114,0.3);
        }

        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
        html { scroll-behavior: smooth; font-size: 16px; }

        body {
            font-family: 'Outfit', sans-serif;
            background: var(--bg);
            color: var(--text);
            min-height: 100vh;
            overflow-x: hidden;
            transition: background .4s ease, color .4s ease;
        }

        a { text-decoration: none; color: inherit; }
        img { max-width: 100%; display: block; }

        ::-webkit-scrollbar { width: 3px; }
        ::-webkit-scrollbar-track { background: var(--bg); }
        ::-webkit-scrollbar-thumb { background: var(--or); }

        #luxury-canvas {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            opacity: .4;
            transition: opacity .4s;
        }
        [data-theme="light"] #luxury-canvas { opacity: .15; }

        .blob-wrap {
            position: fixed;
            inset: 0;
            pointer-events: none;
            z-index: 0;
            overflow: hidden;
        }
        .blob {
            position: absolute;
            border-radius: 50%;
            filter: blur(90px);
            opacity: .06;
        }
        [data-theme="light"] .blob { opacity: .04; }
        .blob-1 {
            width: 600px; height: 600px;
            background: var(--or);
            top: -150px; left: -150px;
            animation: b1 18s ease-in-out infinite;
        }
        .blob-2 {
            width: 500px; height: 500px;
            background: var(--or2);
            bottom: -100px; right: -100px;
            animation: b2 22s ease-in-out infinite;
        }
        @keyframes b1 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(80px,60px) scale(1.15)} }
        @keyframes b2 { 0%,100%{transform:translate(0,0) scale(1)} 50%{transform:translate(-60px,-80px) scale(1.1)} }


        .nav-luxury {
            position: fixed;
            top: 0; left: 0; right: 0;
            z-index: 9999;
            height: 68px;
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 0 2.5rem;
            background: var(--glass);
            backdrop-filter: blur(28px) saturate(180%);
            -webkit-backdrop-filter: blur(28px) saturate(180%);
            border-bottom: 1px solid var(--glass-border);
            transition: all .4s ease;
        }

        .nav-luxury::after {
            content: '';
            position: absolute;
            bottom: -1px; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--or), transparent);
            opacity: .4;
        }

        .nav-brand {
            display: flex;
            align-items: center;
            gap: .75rem;
            text-decoration: none;
        }

        .nav-brand-emblem {
            width: 32px; height: 32px;
            position: relative;
            flex-shrink: 0;
        }
        .nav-brand-emblem svg { width: 100%; height: 100%; }

        .nav-brand-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: 1.2rem;
            font-weight: 400;
            letter-spacing: .18em;
            color: var(--or);
            text-transform: uppercase;
            line-height: 1;
        }
        .nav-brand-sub {
            font-family: 'Space Mono', monospace;
            font-size: .42rem;
            letter-spacing: .25em;
            text-transform: uppercase;
            color: var(--text3);
            margin-top: .15rem;
        }

        .nav-center {
            display: flex;
            align-items: center;
            gap: .25rem;
            position: absolute;
            left: 50%;
            transform: translateX(-50%);
        }

        .nav-link {
            font-family: 'Space Mono', monospace;
            font-size: .58rem;
            letter-spacing: .18em;
            text-transform: uppercase;
            color: var(--text2);
            padding: .45rem .9rem;
            border-radius: 2px;
            text-decoration: none;
            transition: all .25s;
            position: relative;
        }
        .nav-link::after {
            content: '';
            position: absolute;
            bottom: 2px; left: .9rem; right: .9rem;
            height: 1px;
            background: var(--or);
            transform: scaleX(0);
            transition: transform .25s;
        }
        .nav-link:hover { color: var(--or); }
        .nav-link:hover::after { transform: scaleX(1); }

        .nav-controls {
            display: flex;
            align-items: center;
            gap: .5rem;
        }

        .nav-icon-btn {
            width: 36px; height: 36px;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 1px solid var(--or-border);
            border-radius: 2px;
            background: transparent;
            color: var(--text2);
            cursor: pointer;
            transition: all .25s;
            font-size: .95rem;
            position: relative;
        }
        .nav-icon-btn:hover {
            border-color: var(--or);
            color: var(--or);
            background: var(--or-dim);
        }

        .lang-wrap { position: relative; }
        .lang-btn {
            font-family: 'Space Mono', monospace;
            font-size: .52rem;
            letter-spacing: .12em;
            font-weight: 700;
        }
        .lang-dropdown {
            position: absolute;
            top: calc(100% + .5rem);
            right: 0;
            background: var(--glass);
            backdrop-filter: blur(20px);
            border: 1px solid var(--glass-border);
            border-radius: 2px;
            min-width: 110px;
            overflow: hidden;
            opacity: 0;
            visibility: hidden;
            transform: translateY(-6px);
            transition: all .25s cubic-bezier(.23,1,.32,1);
            z-index: 100;
        }
        .lang-dropdown.open {
            opacity: 1;
            visibility: visible;
            transform: translateY(0);
        }
        .lang-opt {
            display: flex;
            align-items: center;
            gap: .6rem;
            padding: .65rem .9rem;
            font-family: 'Space Mono', monospace;
            font-size: .58rem;
            letter-spacing: .12em;
            text-transform: uppercase;
            color: var(--text2);
            cursor: pointer;
            transition: all .2s;
            border-bottom: 1px solid var(--border);
        }
        .lang-opt:last-child { border-bottom: none; }
        .lang-opt:hover { color: var(--or); background: var(--or-dim); }
        .lang-opt.active { color: var(--or); }
        .lang-flag { font-size: 1rem; line-height: 1; }

        .nav-sep {
            width: 1px;
            height: 20px;
            background: var(--or-border);
            margin: 0 .25rem;
        }

        .nav-auth-btn {
            font-family: 'Space Mono', monospace;
            font-size: .55rem;
            letter-spacing: .14em;
            text-transform: uppercase;
            padding: .5rem 1.1rem;
            border: 1px solid var(--or-border);
            color: var(--or);
            background: transparent;
            cursor: pointer;
            transition: all .25s;
            text-decoration: none;
            border-radius: 2px;
            display: inline-block;
        }
        .nav-auth-btn:hover {
            background: var(--or);
            color: var(--bg);
            border-color: var(--or);
        }
        .nav-auth-btn.filled {
            background: var(--or);
            color: var(--bg);
        }
        .nav-auth-btn.filled:hover {
            background: var(--or2);
            border-color: var(--or2);
        }

        .nav-user-badge {
            display: flex;
            align-items: center;
            gap: .5rem;
            font-family: 'Space Mono', monospace;
            font-size: .52rem;
            letter-spacing: .1em;
            color: var(--or);
            border: 1px solid var(--or-border);
            padding: .3rem .75rem;
            border-radius: 2px;
        }
        .user-dot {
            width: 6px; height: 6px;
            border-radius: 50%;
            background: var(--or);
            animation: pulse 2.5s ease-in-out infinite;
        }
        @keyframes pulse { 0%,100%{opacity:1;transform:scale(1)} 50%{opacity:.4;transform:scale(1.3)} }

        .page-sep {
            position: relative;
            height: 80px;
            display: flex;
            align-items: center;
            justify-content: center;
            overflow: visible;
            background: var(--bg);
            z-index: 1;
        }

        .sep-line-full {
            position: absolute;
            top: 50%; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--or-border-hover) 20%, var(--or) 50%, var(--or-border-hover) 80%, transparent);
        }

        .sep-center {
            position: relative;
            z-index: 1;
            background: var(--bg);
            padding: 0 1.5rem;
            display: flex;
            align-items: center;
            gap: .85rem;
        }

        .sep-diamond-lg {
            width: 12px; height: 12px;
            background: var(--or);
            transform: rotate(45deg);
            flex-shrink: 0;
        }
        .sep-diamond-md {
            width: 7px; height: 7px;
            border: 1px solid rgba(197,165,114,0.5);
            transform: rotate(45deg);
            flex-shrink: 0;
        }
        .sep-diamond-sm {
            width: 4px; height: 4px;
            border: 1px solid rgba(197,165,114,0.3);
            transform: rotate(45deg);
            flex-shrink: 0;
        }

        .sep-label {
            font-family: 'Space Mono', monospace;
            font-size: .5rem;
            letter-spacing: .3em;
            text-transform: uppercase;
            color: rgba(197,165,114,0.55);
            white-space: nowrap;
        }

        .sep-corner {
            position: absolute;
            width: 16px; height: 16px;
            border-color: rgba(197,165,114,0.22);
            border-style: solid;
        }
        .sep-corner.tl { top:8px; left:16px; border-width:1px 0 0 1px; }
        .sep-corner.tr { top:8px; right:16px; border-width:1px 1px 0 0; }
        .sep-corner.bl { bottom:8px; left:16px; border-width:0 0 1px 1px; }
        .sep-corner.br { bottom:8px; right:16px; border-width:0 1px 1px 0; }

        .btn-or {
            font-family: 'Space Mono', monospace;
            font-size: .62rem;
            letter-spacing: .14em;
            text-transform: uppercase;
            padding: .85rem 2rem;
            background: var(--or);
            color: var(--bg) !important;
            border: none;
            cursor: pointer;
            transition: all .3s;
            border-radius: 2px;
            text-decoration: none !important;
            display: inline-block;
        }
        .btn-or:hover {
            background: var(--or3);
            transform: translateY(-2px);
            box-shadow: 0 8px 28px rgba(197,165,114,0.35);
        }

        .btn-outline-or {
            font-family: 'Space Mono', monospace;
            font-size: .62rem;
            letter-spacing: .14em;
            text-transform: uppercase;
            padding: .85rem 2rem;
            background: transparent;
            color: var(--text) !important;
            border: 1px solid rgba(197,165,114,0.35);
            cursor: pointer;
            transition: all .3s;
            border-radius: 2px;
            text-decoration: none !important;
            display: inline-block;
        }
        .btn-outline-or:hover {
            border-color: var(--or);
            color: var(--or) !important;
            transform: translateY(-2px);
        }

        .input-lux {
            width: 100%;
            background: rgba(197,165,114,0.04);
            border: 1px solid var(--or-border);
            border-radius: 2px;
            padding: .8rem 1rem;
            color: var(--text);
            font-family: 'Outfit', sans-serif;
            font-size: .875rem;
            font-weight: 300;
            outline: none;
            transition: border-color .25s;
        }
        .input-lux:focus { border-color: rgba(197,165,114,0.55); }
        .input-lux::placeholder { color: var(--text3); }

        .label-lux {
            font-family: 'Space Mono', monospace;
            font-size: .56rem;
            letter-spacing: .16em;
            text-transform: uppercase;
            color: var(--text3);
            display: block;
            margin-bottom: .4rem;
        }

        .glass-lux {
            background: var(--glass);
            backdrop-filter: blur(30px) saturate(150%);
            -webkit-backdrop-filter: blur(30px) saturate(150%);
            border: 1px solid var(--glass-border);
            border-radius: 3px;
        }

        .reveal-lux {
            opacity: 0;
            transform: translateY(32px);
            transition: opacity .95s cubic-bezier(.23,1,.32,1), transform .95s cubic-bezier(.23,1,.32,1);
        }
        .reveal-lux.visible { opacity: 1; transform: translateY(0); }

        .reveal-lux:nth-child(2) { transition-delay: .1s; }
        .reveal-lux:nth-child(3) { transition-delay: .2s; }
        .reveal-lux:nth-child(4) { transition-delay: .3s; }

        .scroll-track {
            position: fixed;
            right: 1.25rem;
            top: 50%;
            transform: translateY(-50%);
            display: flex;
            flex-direction: column;
            gap: .4rem;
            z-index: 100;
        }
        .s-dot {
            width: 3px;
            background: rgba(197,165,114,0.18);
            border-radius: 2px;
            height: 18px;
            cursor: pointer;
            transition: all .3s;
        }
        .s-dot.active { height: 28px; background: var(--or); }
        .s-dot:hover { background: rgba(197,165,114,0.45); }

        .bookmark-track {
            position: fixed;
            left: 1.25rem;
            top: 50%;
            transform: translateY(-50%);
            display: flex;
            flex-direction: column;
            gap: .6rem;
            z-index: 100;
        }
        .b-mark {
            width: 3px;
            height: 50px;
            background: rgba(197,165,114,0.12);
            border-radius: 2px;
            cursor: pointer;
            transition: all .4s cubic-bezier(.23,1,.32,1);
            position: relative;
        }
        .b-mark.active {
            height: 70px;
            background: var(--or);
            box-shadow: 0 0 16px rgba(197,165,114,0.4);
        }
        .b-mark:hover { background: rgba(197,165,114,0.4); }
        .b-label {
            position: absolute;
            left: 14px; top: 50%;
            transform: translateY(-50%);
            white-space: nowrap;
            font-family: 'Space Mono', monospace;
            font-size: .48rem;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--or);
            opacity: 0;
            transition: opacity .25s;
            pointer-events: none;
        }
        .b-mark:hover .b-label { opacity: 1; }

        .book-section {
            position: relative;
            z-index: 1;
            background: var(--bg);
            transition: background .4s;
        }
        .book-section::before {
            content: '';
            position: absolute;
            top: 0; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--or-border-hover), transparent);
            opacity: .6;
        }
        .book-section[data-page]::after {
            content: attr(data-page);
            position: absolute;
            bottom: 1.5rem; right: 4rem;
            font-family: 'Space Mono', monospace;
            font-size: .48rem;
            letter-spacing: .3em;
            color: var(--or);
            opacity: .2;
        }

        .sec-chapter {
            font-family: 'Space Mono', monospace;
            font-size: .5rem;
            letter-spacing: .35em;
            text-transform: uppercase;
            color: var(--or);
            text-align: center;
            margin-bottom: 3.5rem;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 1.25rem;
        }
        .sec-chapter::before,
        .sec-chapter::after {
            content: '';
            width: 60px; height: 1px;
            background: linear-gradient(90deg, transparent, var(--or));
        }
        .sec-chapter::after { background: linear-gradient(90deg, var(--or), transparent); }

        .sec-h2 {
            font-family: 'Cormorant Garamond', serif;
            font-size: clamp(2rem, 4vw, 3rem);
            font-weight: 300;
            line-height: 1.1;
            letter-spacing: -.01em;
        }
        .sec-h2 em { font-style: italic; color: var(--or); }

        .toast-lux {
            position: fixed;
            top: 80px; right: 1.5rem;
            z-index: 9998;
            max-width: 300px;
            padding: .85rem 1.1rem;
            border-radius: 2px;
            font-family: 'Outfit', sans-serif;
            font-size: .78rem;
            font-weight: 300;
            letter-spacing: .03em;
            animation: toastIn .4s ease;
        }
        @keyframes toastIn { from{opacity:0;transform:translateX(16px)} to{opacity:1;transform:translateX(0)} }
        .toast-lux.success { background:rgba(197,165,114,0.1); border:1px solid rgba(197,165,114,0.3); color:var(--or2); }
        .toast-lux.danger { background:rgba(239,68,68,0.08); border:1px solid rgba(239,68,68,0.25); color:#fca5a5; }

        .footer-lux {
            background: var(--bg2);
            border-top: 1px solid var(--border);
            padding: 4rem 4rem 2rem;
            position: relative;
            z-index: 1;
            transition: background .4s;
        }
        .footer-lux::before {
            content: '';
            position: absolute;
            top: -1px; left: 0; right: 0;
            height: 1px;
            background: linear-gradient(90deg, transparent, var(--or), transparent);
        }

        .footer-grid {
            display: grid;
            grid-template-columns: 2fr 1fr 1fr 1fr;
            gap: 4rem;
            margin-bottom: 3rem;
        }

        .footer-brand-col {}
        .footer-logo-text {
            font-family: 'Cormorant Garamond', serif;
            font-size: 2rem;
            font-weight: 300;
            letter-spacing: .15em;
            color: var(--or);
            margin-bottom: .5rem;
        }
        .footer-tagline {
            font-family: 'Space Mono', monospace;
            font-size: .48rem;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--text3);
            margin-bottom: 1.5rem;
        }
        .footer-desc {
            font-size: .82rem;
            font-weight: 300;
            color: var(--text2);
            line-height: 1.8;
            max-width: 260px;
        }

        .footer-col-title {
            font-family: 'Space Mono', monospace;
            font-size: .52rem;
            letter-spacing: .2em;
            text-transform: uppercase;
            color: var(--or);
            margin-bottom: 1.25rem;
            padding-bottom: .5rem;
            border-bottom: 1px solid var(--border);
        }

        .footer-links { list-style: none; }
        .footer-links li { margin-bottom: .65rem; }
        .footer-links a {
            font-size: .8rem;
            font-weight: 300;
            color: var(--text2);
            text-decoration: none;
            transition: all .2s;
            display: flex;
            align-items: center;
            gap: .5rem;
        }
        .footer-links a::before {
            content: '—';
            color: var(--or);
            font-size: .65rem;
            opacity: 0;
            transform: translateX(-6px);
            transition: all .2s;
        }
        .footer-links a:hover { color: var(--or); padding-left: .4rem; }
        .footer-links a:hover::before { opacity: 1; transform: translateX(0); }

        .footer-bottom {
            padding-top: 2rem;
            border-top: 1px solid var(--border);
            display: flex;
            align-items: center;
            justify-content: space-between;
            flex-wrap: wrap;
            gap: 1rem;
        }
        .footer-copy {
            font-family: 'Space Mono', monospace;
            font-size: .5rem;
            letter-spacing: .12em;
            color: var(--text3);
        }
        .footer-copy span { color: var(--or); }

        .footer-tech {
            display: flex;
            gap: 1rem;
        }
        .tech-badge {
            font-family: 'Space Mono', monospace;
            font-size: .48rem;
            letter-spacing: .1em;
            color: var(--text3);
            border: 1px solid var(--border);
            padding: .25rem .6rem;
            border-radius: 2px;
        }

        main {
            position: relative;
            z-index: 1;
            padding-top: 68px;
        }

        .eyebrow {
            font-family: 'Space Mono', monospace;
            font-size: .56rem;
            letter-spacing: .25em;
            text-transform: uppercase;
            color: var(--or);
            display: flex;
            align-items: center;
            gap: .75rem;
            margin-bottom: .85rem;
        }
        .eyebrow::before {
            content: '';
            width: 22px; height: 1px;
            background: var(--or);
            flex-shrink: 0;
        }

        @media (max-width: 900px) {
            .nav-center { display: none; }
            .bookmark-track { display: none; }
            .footer-grid { grid-template-columns: 1fr 1fr; gap: 2rem; }
        }
        @media (max-width: 600px) {
            .nav-luxury { padding: 0 1rem; }
            .footer-lux { padding: 2.5rem 1.25rem 1.5rem; }
            .footer-grid { grid-template-columns: 1fr; }
        }
    </style>
    {% block stylesheets %}{% endblock %}
</head>
<body>

<canvas id="luxury-canvas"></canvas>

<div class="blob-wrap">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
</div>


<nav class="nav-luxury" id="navbar">

    <a href="{{ path('app_home') }}" class="nav-brand">
        <div class="nav-brand-emblem">
            <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <polygon points="16,2 30,10 30,22 16,30 2,22 2,10" fill="none" stroke="#c5a572" stroke-width="1"/>
