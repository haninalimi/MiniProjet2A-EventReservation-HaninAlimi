<!DOCTYPE html>
<html lang="fr" data-theme="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}EventApp — L'Art de la Réservation{% endblock %}</title>
    <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;1,300;1,400;1,600&family=Outfit:wght@200;300;400;500;600&family=Space+Mono:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.0/font/bootstrap-icons.css" rel="stylesheet">
    <link rel="stylesheet" href="{{ asset('css/base.css') }}">
    {% block stylesheets %}{% endblock %}
</head>
<body>

<canvas id="luxury-canvas"></canvas>

<div class="blob-wrap">
    <div class="blob blob-1"></div>
    <div class="blob blob-2"></div>
</div>

<nav class="nav-luxury" id="navbar">

    <a href="{{ path('app_home') }}" class="nav-brand">
        <div class="nav-brand-emblem">
            <svg viewBox="0 0 32 32" fill="none" xmlns="http://www.w3.org/2000/svg">
                <polygon points="16,2 30,10 30,22 16,30 2,22 2,10" fill="none" stroke="#c5a572" stroke-width="1"/>
                <polygon points="16,7 25,12 25,20 16,25 7,20 7,12" fill="none" stroke="#c5a572" stroke-width=".5" opacity=".5"/>
                <circle cx="16" cy="16" r="3" fill="#c5a572"/>
                <circle cx="16" cy="16" r="1.2" fill="#080808"/>
            </svg>
        </div>
        <div>
            <div class="nav-brand-text">EventApp</div>
            <div class="nav-brand-sub">L'art de réserver</div>
        </div>
    </a>

    <div class="nav-center">
        <a href="{{ path('event_index') }}" class="nav-link">Événements</a>
        <a href="{{ path('app_home') }}#how" class="nav-link">Comment ça marche</a>
        <a href="{{ path('app_home') }}#about" class="nav-link">À propos</a>
    </div>

    <div class="nav-controls">

        <button class="nav-icon-btn" id="themeToggle" title="Changer le thème" aria-label="Toggle theme">
            <i class="bi bi-moon-stars-fill" id="themeIcon"></i>
        </button>

        <div class="lang-wrap">
            <button class="nav-icon-btn lang-btn" id="langBtn" title="Changer la langue" aria-label="Language">
                <span id="langLabel">FR</span>
            </button>
            <div class="lang-dropdown" id="langDropdown">
                <div class="lang-opt active" data-lang="fr" onclick="setLang('fr')">
                    <span class="lang-flag">🇫🇷</span>
                    <span>Français</span>
                </div>
                <div class="lang-opt" data-lang="en" onclick="setLang('en')">
                    <span class="lang-flag">🇬🇧</span>
                    <span>English</span>
                </div>
                <div class="lang-opt" data-lang="ar" onclick="setLang('ar')">
                    <span class="lang-flag">🇹🇳</span>
                    <span>العربية</span>
                </div>
            </div>
        </div>

        <div class="nav-sep"></div>

        <div id="nav-guest-zone" style="display:flex;align-items:center;gap:.5rem;">
            <a href="{{ path('app_login') }}" class="nav-auth-btn">Connexion</a>
            <a href="{{ path('app_register') }}" class="btn-outline-or">Créer un compte</a>
        </div>

        <div id="nav-user-zone" style="display:none;align-items:center;gap:.5rem;">
            <div class="nav-user-badge">
                <div class="user-dot"></div>
                <span id="nav-email-txt"></span>
            </div>
            <button onclick="handleLogout()" class="nav-icon-btn" title="Déconnexion">
                <i class="bi bi-box-arrow-right"></i>
            </button>
        </div>

    </div>
</nav>

<div class="bookmark-track" id="bookmarkTrack"></div>

<div class="scroll-track" id="scrollTrack"></div>

{% for type, messages in app.flashes %}
    {% for message in messages %}
    <div class="toast-lux {{ type }}">{{ message }}</div>
    {% endfor %}
{% endfor %}

<main>{% block body %}{% endblock %}</main>

<div class="page-sep" style="background:var(--bg2);">
    <div class="sep-line-full"></div>
    <div class="sep-center" style="background:var(--bg2);">
        <div class="sep-diamond-sm"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-lg"></div>
        <div class="sep-diamond-md"></div>
        <div class="sep-diamond-sm"></div>
    </div>
</div>

<footer class="footer-lux">
    <div class="footer-grid">
        <div class="footer-brand-col">
            <div class="footer-logo-text">EventApp</div>
            <div class="footer-tagline">L'art de réserver l'exceptionnel</div>
            <p class="footer-desc">
                Réservez vos événements préférés en quelques secondes. Sécurisé, rapide et élégant — la nouvelle référence de la réservation en ligne.
            </p>
        </div>
        <div>
            <div class="footer-col-title">Événements</div>
            <ul class="footer-links">
                <li><a href="{{ path('event_index') }}">Tous les événements</a></li>
                <li><a href="{{ path('event_index') }}?upcoming=1">À venir</a></li>
                <li><a href="{{ path('event_index') }}?past=1">Passés</a></li>
            </ul>
        </div>
        <div>
            <div class="footer-col-title">Mon Compte</div>
            <ul class="footer-links">
                <li><a href="#">Connexion</a></li>
                <li><a href="#">Inscription</a></li>
                <li><a href="#">Mon profil</a></li>
            </ul>
        </div>
        <div>
            <div class="footer-col-title">Correspondance</div>
            <ul class="footer-links">
                <li><a href="#">Nous écrire</a></li>
                <li><a href="#">FAQ</a></li>
                <li><a href="#">Politique de confidentialité</a></li>
            </ul>
        </div>
    </div>

    <div class="footer-bottom">
        <div class="footer-copy">
            © 2026 — <span>EventApp</span> · FIA4-GL · ISSAT Sousse · HANIN ALILMI
        </div>
    </div>
</footer>

<script type="module" src="{{ asset('js/base.js') }}"></script>
{% block javascripts %}{% endblock %}
</body>
</html>